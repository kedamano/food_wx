<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.food.mapper.OrderDetailMapper">

    <resultMap id="BaseResultMap" type="com.food.entity.OrderDetail">
        <id column="detail_id" jdbcType="INTEGER" property="detailId"/>
        <result column="order_id" jdbcType="INTEGER" property="orderId"/>
        <result column="food_id" jdbcType="INTEGER" property="foodId"/>
        <result column="food_name" jdbcType="VARCHAR" property="foodName"/>
        <result column="price" jdbcType="DECIMAL" property="price"/>
        <result column="quantity" jdbcType="INTEGER" property="quantity"/>
        <result column="total_price" jdbcType="DECIMAL" property="totalPrice"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
    </resultMap>

    <sql id="BaseColumnList">
        detail_id, order_id, food_id, food_name, price, quantity, total_price, create_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="detailId">
        INSERT INTO order_details (
            order_id, food_id, food_name, price, quantity, total_price
        ) VALUES (
            #{orderId}, #{foodId}, #{foodName}, #{price}, #{quantity}, #{totalPrice}
        )
    </insert>

    <update id="update">
        UPDATE order_details
        SET order_id = #{orderId},
            food_id = #{foodId},
            food_name = #{foodName},
            price = #{price},
            quantity = #{quantity},
            total_price = #{totalPrice}
        WHERE detail_id = #{detailId}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM order_details
        WHERE detail_id = #{detailId}
    </select>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM order_details
        WHERE order_id = #{orderId}
        ORDER BY create_time DESC
    </select>

    <delete id="deleteById">
        DELETE FROM order_details
        WHERE detail_id = #{detailId}
    </delete>

    <delete id="deleteByOrderId">
        DELETE FROM order_details
        WHERE order_id = #{orderId}
    </delete>

</mapper>