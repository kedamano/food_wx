<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.food.mapper.CouponMapper">

    <resultMap id="BaseResultMap" type="com.food.entity.Coupon">
        <id column="coupon_id" jdbcType="INTEGER" property="couponId"/>
        <result column="coupon_name" jdbcType="VARCHAR" property="couponName"/>
        <result column="discount_amount" jdbcType="DECIMAL" property="discountAmount"/>
        <result column="min_amount" jdbcType="DECIMAL" property="minAmount"/>
        <result column="start_time" jdbcType="TIMESTAMP" property="startTime"/>
        <result column="end_time" jdbcType="TIMESTAMP" property="endTime"/>
        <result column="status" jdbcType="INTEGER" property="status"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumnList">
        coupon_id, coupon_name, discount_amount, min_amount, start_time, end_time, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM coupons
        WHERE coupon_id = #{couponId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM coupons
        ORDER BY status ASC, end_time ASC
    </select>
    
    <select id="selectAvailable" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM coupons
        WHERE status = 1 AND end_time > NOW()
        ORDER BY discount_amount DESC
    </select>

</mapper>
