<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.food.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.food.entity.Category">
        <id column="category_id" jdbcType="INTEGER" property="categoryId"/>
        <result column="category_name" jdbcType="VARCHAR" property="categoryName"/>
        <result column="icon" jdbcType="VARCHAR" property="icon"/>
        <result column="sort_order" jdbcType="INTEGER" property="sortOrder"/>
        <result column="status" jdbcType="INTEGER" property="status"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumnList">
        category_id, category_name, icon, sort_order, status, create_time, update_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO categories (
            category_name, icon, sort_order, status
        ) VALUES (
            #{categoryName}, #{icon}, #{sortOrder}, #{status}
        )
    </insert>

    <update id="update">
        UPDATE categories
        SET category_name = #{categoryName},
            icon = #{icon},
            sort_order = #{sortOrder},
            status = #{status},
            update_time = CURRENT_TIMESTAMP
        WHERE category_id = #{categoryId}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM categories
        WHERE category_id = #{categoryId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM categories
        WHERE status = 1
        ORDER BY sort_order ASC
    </select>

</mapper>