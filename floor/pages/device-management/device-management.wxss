/* 登录设备管理页面样式 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
  background: #fff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.header-placeholder {
  width: 60rpx;
}

.device-list {
  padding: 20rpx 30rpx;
}

.device-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.device-item.current {
  border: 2rpx solid #4CAF50;
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.device-icon text {
  font-size: 36rpx;
  color: #666;
}

.device-info {
  flex: 1;
}

.device-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.device-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.device-badge {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  border-radius: 8rpx;
}

.device-type {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.device-meta {
  display: flex;
  flex-direction: column;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.meta-item text:first-child {
  margin-right: 8rpx;
}

.device-action {
  margin-left: 20rpx;
}

.unbind-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  border: none;
  border-radius: 8rpx;
}

.unbind-btn::after {
  border: none;
}

.unbind-btn text {
  margin-right: 8rpx;
}

.action-section {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  border: none;
  border-radius: 12rpx;
}

.danger-btn::after {
  border: none;
}

.danger-btn text {
  margin-right: 12rpx;
}

.security-tip {
  display: flex;
  padding: 30rpx;
  margin: 40rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 40rpx;
  color: #ff9800;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
