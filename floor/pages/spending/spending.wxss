/* 消费明细页面 */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.2);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 月份筛选 */
.filter-section {
  margin-bottom: 20rpx;
}

.filter-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #FF6633;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-text {
  font-size: 24rpx;
  color: #666;
}

.filter-item.active .filter-text {
  color: #fff;
  font-weight: 500;
}

/* 消费列表 */
.spending-list {
  padding-bottom: 20rpx;
}

.spending-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.spending-card:active {
  transform: scale(0.98);
}

.card-left {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.store-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF0EB;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-icon-text {
  font-size: 48rpx;
  color: #FF6633;
  font-weight: 700;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.store-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6633;
}

.item-names {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.spending-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  color: #ddd;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.safe-area-bottom {
  height: 40rpx;
}
