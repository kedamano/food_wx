/* 个人中心 - 大众点评风格 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page-container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 用户头部 */
.user-header {
  position: relative;
  padding: 0 0 0 0;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #FF6633, #FF8855, #FFaa77);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 80rpx 32rpx 32rpx;
}

.user-avatar-wrap {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-border {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 36rpx;
  height: 36rpx;
  background: #FFD700;
  border-radius: 50%;
  border: 3rpx solid #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.user-level-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.level-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.level-icon {
  width: 28rpx;
  height: 28rpx;
}

.user-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.header-action {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.setting-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 统计条 */
.stats-bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-20rpx);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.stat-num.highlight {
  color: #FF6633;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

/* 区块卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.view-all {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.view-all-text {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 订单区域 */
.order-grid {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.order-icon {
  width: 48rpx;
  height: 48rpx;
}

.order-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

.order-text {
  font-size: 24rpx;
  color: #666;
}

/* 工具区域 */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
}

.tool-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.tool-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.tool-text {
  font-size: 24rpx;
  color: #666;
}

.coupon-tool-icon {
  position: relative;
}

.coupon-dot {
  position: absolute;
  top: 0;
  right: -4rpx;
  width: 14rpx;
  height: 14rpx;
  background: #FF3B30;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出按钮 */
.logout-section {
  margin: 40rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF3B30;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #f5f5f5;
}

.bottom-safe {
  height: 40rpx;
}
