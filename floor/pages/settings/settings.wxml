<!-- 设置页面 - 精致版 -->
<scroll-view class="container" scroll-y>
  <!-- 头部 -->
  <view class="header-section">
    <view class="header-content">
      <text class="header-title">设置</text>
      <text class="header-subtitle">管理您的偏好设置</text>
    </view>
  </view>

  <!-- 账号设置 -->
  <view class="settings-section">
    <text class="section-title">账号设置</text>
    <view class="setting-list">
      <view class="setting-item" bindtap="onAccountInfo">
        <view class="item-left">
          <view class="item-icon account">
            <text class="fa fa-user"></text>
          </view>
          <text class="item-text">账号信息</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="onSecurity">
        <view class="item-left">
          <view class="item-icon security">
            <text class="fa fa-lock"></text>
          </view>
          <text class="item-text">安全设置</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="onPrivacy">
        <view class="item-left">
          <view class="item-icon privacy">
            <text class="fa fa-shield-alt"></text>
          </view>
          <text class="item-text">隐私设置</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 通知设置 -->
  <view class="settings-section">
    <text class="section-title">通知设置</text>
    <view class="setting-list">
      <view class="setting-item switch">
        <view class="item-left">
          <view class="item-icon notifications">
            <text class="fa fa-bell"></text>
          </view>
          <text class="item-text">订单通知</text>
        </view>
        <switch class="item-switch" checked="{{settings.orderNotifications}}" bind:change="onSwitchChange" data-setting="orderNotifications" />
      </view>
      <view class="setting-item switch">
        <view class="item-left">
          <view class="item-icon promotions">
            <text class="fa fa-bullhorn"></text>
          </view>
          <text class="item-text">促销通知</text>
        </view>
        <switch class="item-switch" checked="{{settings.promoNotifications}}" bind:change="onSwitchChange" data-setting="promoNotifications" />
      </view>
      <view class="setting-item switch">
        <view class="item-left">
          <view class="item-icon customer">
            <text class="fa fa-comment-dots"></text>
          </view>
          <text class="item-text">客服消息</text>
        </view>
        <switch class="item-switch" checked="{{settings.customerServiceNotifications}}" bind:change="onSwitchChange" data-setting="customerServiceNotifications" />
      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="settings-section">
    <text class="section-title">通用设置</text>
    <view class="setting-list">
      <view class="setting-item switch">
        <view class="item-left">
          <view class="item-icon location">
            <text class="fa fa-globe"></text>
          </view>
          <text class="item-text">自动定位</text>
        </view>
        <switch class="item-switch" checked="{{settings.autoLocation}}" bind:change="onSwitchChange" data-setting="autoLocation" />
      </view>
      <view class="setting-item switch">
        <view class="item-left">
          <view class="item-icon update">
            <text class="fa fa-sync-alt"></text>
          </view>
          <text class="item-text">自动更新</text>
        </view>
        <switch class="item-switch" checked="{{settings.autoUpdate}}" bind:change="onSwitchChange" data-setting="autoUpdate" />
      </view>
      <view class="setting-item" bindtap="onLanguage">
        <view class="item-left">
          <view class="item-icon language">
            <text class="fa fa-language"></text>
          </view>
          <text class="item-text">语言设置</text>
        </view>
        <view class="item-value">
          <text class="value-text">{{settings.language}}</text>
          <text class="item-arrow">→</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onClearCache">
        <view class="item-left">
          <view class="item-icon cache">
            <text class="fa fa-broom"></text>
          </view>
          <text class="item-text">清除缓存</text>
        </view>
        <view class="item-value">
          <text class="value-text">{{cacheSize}}</text>
          <text class="item-arrow">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于我们 -->
  <view class="settings-section">
    <text class="section-title">关于我们</text>
    <view class="setting-list">
      <view class="setting-item" bindtap="onAbout">
        <view class="item-left">
          <view class="item-icon about">
            <text class="fa fa-info-circle"></text>
          </view>
          <text class="item-text">关于小程序</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="onHelp">
        <view class="item-left">
          <view class="item-icon help">
            <text class="fa fa-question-circle"></text>
          </view>
          <text class="item-text">帮助中心</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="onFeedback">
        <view class="item-left">
          <view class="item-icon feedback">
            <text class="fa fa-comment-alt"></text>
          </view>
          <text class="item-text">意见反馈</text>
        </view>
        <text class="item-arrow">→</text>
      </view>
      <view class="setting-item" bindtap="onVersion">
        <view class="item-left">
          <view class="item-icon version">
            <text class="fa fa-sync-alt"></text>
          </view>
          <text class="item-text">检查更新</text>
        </view>
        <view class="item-value">
          <text class="value-text">v{{version}}</text>
          <text class="item-arrow">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">
      <text class="fa fa-sign-out-alt btn-icon"></text>
      <text class="btn-text">退出登录</text>
    </button>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</scroll-view>