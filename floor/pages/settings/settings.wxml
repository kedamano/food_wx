<view class="page-settings">
  <!-- 账号与安全 -->
  <view class="settings-group">
    <view class="group-title">账号与安全</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onAccountInfo" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>👤</text></view>
          <text class="s-title">账号信息</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onSecurity" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>🔒</text></view>
          <text class="s-title">安全设置</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onPrivacy" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>🛡️</text></view>
          <text class="s-title">隐私设置</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新消息通知 -->
  <view class="settings-group">
    <view class="group-title">新消息通知</view>
    <view class="s-card">
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>🔔</text></view>
          <text class="s-title">订单通知</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{settings.orderNotifications}}" bindchange="onSwitchChange" data-setting="orderNotifications" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>📢</text></view>
          <text class="s-title">促销通知</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{settings.promoNotifications}}" bindchange="onSwitchChange" data-setting="promoNotifications" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell s-cell-last">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>💬</text></view>
          <text class="s-title">客服消息</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{settings.customerServiceNotifications}}" bindchange="onSwitchChange" data-setting="customerServiceNotifications" color="#FF6633" />
        </view>
      </view>
    </view>
  </view>

  <!-- 通用 -->
  <view class="settings-group">
    <view class="group-title">通用</view>
    <view class="s-card">
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>📍</text></view>
          <text class="s-title">自动定位</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{settings.autoLocation}}" bindchange="onSwitchChange" data-setting="autoLocation" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>🔄</text></view>
          <text class="s-title">自动更新</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{settings.autoUpdate}}" bindchange="onSwitchChange" data-setting="autoUpdate" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell" bindtap="onLanguage" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>🌐</text></view>
          <text class="s-title">语言</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{settings.language}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onClearCache" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>🧹</text></view>
          <text class="s-title">清除缓存</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{cacheSize}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="settings-group">
    <view class="group-title">关于</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onAbout" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>ℹ️</text></view>
          <text class="s-title">关于小程序</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onHelp" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>❓</text></view>
          <text class="s-title">帮助中心</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onFeedback" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>✉️</text></view>
          <text class="s-title">意见反馈</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onVersion" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>🔄</text></view>
          <text class="s-title">检查更新</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">v{{version}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="settings-group group-last">
    <view class="s-card card-logout">
      <view class="s-cell s-cell-last" bindtap="onLogout" hover-class="s-cell-hover">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
