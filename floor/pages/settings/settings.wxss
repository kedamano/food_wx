/* ========================================
   设置页面 - 大众点评风格
   ======================================== */

/* 页面 */
page {
  background: #f5f5f5;
}

.page-settings {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- 分组 ---------- */
.settings-group {
  margin-bottom: 24rpx;
}

.group-last {
  margin-bottom: 0;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片 ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

/* ---------- Cell ---------- */
.s-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  background: #fff;
  position: relative;
}

.s-cell::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.s-cell-last::after {
  display: none;
}

.s-cell-hover {
  background: #fafafa;
}

/* ---------- Cell 左侧 ---------- */
.s-cell-hd {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

/* ---------- 圆形图标 ---------- */
.s-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.s-icon text {
  font-size: 30rpx;
}

/* 图标配色 - 柔和马卡龙色 */
.s-icon-orange {
  background: rgba(255, 102, 51, 0.1);
}
.s-icon-blue {
  background: rgba(59, 130, 246, 0.1);
}
.s-icon-green {
  background: rgba(34, 197, 94, 0.1);
}
.s-icon-purple {
  background: rgba(139, 92, 246, 0.1);
}
.s-icon-gray {
  background: rgba(107, 114, 128, 0.1);
}

/* ---------- 标题 ---------- */
.s-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
}

/* ---------- Cell 右侧 ---------- */
.s-cell-ft {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.s-desc {
  font-size: 26rpx;
  color: #999;
}

.s-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* ---------- 开关 ---------- */
.s-switch {
  transform: scale(0.82);
}

/* ---------- 退出登录 ---------- */
.card-logout {
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.logout-text {
  width: 100%;
  text-align: center;
  font-size: 30rpx;
  color: #FF3B30;
  font-weight: 500;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
