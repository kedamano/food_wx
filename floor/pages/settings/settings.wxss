/* 设置页面 - 现代化CSS */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部 */
.header-section {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 设置区域 */
.settings-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.section-title {
  display: block;
  padding: 30rpx 30rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  background: #F9F9F9;
}

.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  transition: all 0.3s ease;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #F9F9F9;
}

.setting-item.switch {
  padding: 24rpx 30rpx;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.item-icon .icon {
  font-size: 32rpx;
}

.item-icon.account {
  background: #FFF0EB;
  color: #FF6633;
}

.item-icon.security {
  background: #E8F4FF;
  color: #2196F3;
}

.item-icon.privacy {
  background: #FFF3E0;
  color: #FF9800;
}

.item-icon.notifications {
  background: #FFF0EB;
  color: #FF6633;
}

.item-icon.promotions {
  background: #F3E5F5;
  color: #9C27B0;
}

.item-icon.customer {
  background: #E3F2FD;
  color: #2196F3;
}

.item-icon.location {
  background: #FFF3E0;
  color: #FF9800;
}

.item-icon.update {
  background: #FFF0EB;
  color: #FF6633;
}

.item-icon.language {
  background: #E3F2FD;
  color: #2196F3;
}

.item-icon.cache {
  background: #F5F5F5;
  color: #666666;
}

.item-icon.about {
  background: #FFF0EB;
  color: #FF6633;
}

.item-icon.help {
  background: #E3F2FD;
  color: #2196F3;
}

.item-icon.feedback {
  background: #FFF3E0;
  color: #FF9800;
}

.item-icon.version {
  background: #F3E5F5;
  color: #9C27B0;
}

.item-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.item-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  transition: transform 0.3s ease;
}

.setting-item:active .item-arrow {
  transform: translateX(4rpx);
}

.item-value {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.value-text {
  font-size: 24rpx;
  color: #666666;
}

.item-switch {
  transform: scale(0.9);
  margin-left: 20rpx;
}

/* 退出登录 */
.logout-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: #FFE8E8;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.logout-btn:active {
  background: #FFD1D1;
  transform: scale(0.98);
}

.logout-btn .btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #FF6B6B;
}

.logout-btn .btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}