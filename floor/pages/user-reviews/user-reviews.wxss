/* 用户评价页面样式 */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
}

.header-section {
  margin-bottom: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.reviews-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-count {
  font-size: 24rpx;
  color: #999999;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-card {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.review-card:active {
  transform: scale(0.98);
  background: #F5F5F5;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.food-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #E0E0E0;
}

.food-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.rating-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
  color: #E0E0E0;
}

.star.active {
  color: #FFD700;
}

.review-time {
  font-size: 22rpx;
  color: #999999;
}

.review-content {
  margin-bottom: 16rpx;
}

.review-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.review-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #E0E0E0;
}

.review-actions {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.btn {
  padding: 20rpx 48rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
  color: #FFFFFF;
}

.safe-area-bottom {
  height: 40rpx;
}
