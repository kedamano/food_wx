/* 关于小程序页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx 20rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
}

.header-placeholder {
  width: 80rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: #fff;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.2);
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-top: 30rpx;
}

.slogan {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

.version-badge {
  margin-top: 20rpx;
  padding: 8rpx 24rpx;
  background: #e8f5e9;
  border-radius: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 功能特点 */
.features-section {
  margin: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 版本信息 */
.info-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #333;
}

.info-value {
  font-size: 28rpx;
  color: #999;
}

/* 操作按钮 */
.action-section {
  padding: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #333;
}

/* 版权 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}
