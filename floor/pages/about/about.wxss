/* 关于页面 - 统一设置风格 */
page {
  background: #f5f5f5;
}

.page-sub {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- Logo 卡片 ---------- */
.logo-card {
  margin-bottom: 24rpx;
}

.logo-row {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.logo-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(255, 102, 51, 0.25);
}

.logo-icon {
  font-size: 48rpx;
}

.logo-info {
  display: flex;
  flex-direction: column;
}

.logo-name {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.logo-desc {
  font-size: 26rpx;
  color: #999;
}

.version-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.version-label {
  font-size: 28rpx;
  color: #666;
}

.version-value {
  font-size: 26rpx;
  color: #FF6633;
  font-weight: 500;
}

/* ---------- 功能特点网格 ---------- */
.feature-grid {
  margin: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.feature-emoji {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.feature-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* ---------- 分组 ---------- */
.sub-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片 ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.s-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  background: #fff;
  position: relative;
}

.s-cell::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.s-cell-last::after {
  display: none;
}

.s-cell-hover {
  background: #fafafa;
}

.s-cell-hd {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.s-cell-ft {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* ---------- 圆形图标 ---------- */
.s-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.s-icon text {
  font-size: 30rpx;
}

.s-icon-orange { background: rgba(255, 102, 51, 0.1); }
.s-icon-blue { background: rgba(59, 130, 246, 0.1); }
.s-icon-green { background: rgba(34, 197, 94, 0.1); }
.s-icon-purple { background: rgba(139, 92, 246, 0.1); }
.s-icon-gray { background: rgba(107, 114, 128, 0.1); }

/* ---------- 文字 ---------- */
.s-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
}

.s-desc {
  font-size: 26rpx;
  color: #999;
}

.s-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* ---------- 版权 ---------- */
.copyright-area {
  display: flex;
  justify-content: center;
  padding: 40rpx 24rpx 16rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #ccc;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
