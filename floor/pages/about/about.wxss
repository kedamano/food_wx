/* 关于小程序页面样式 */
page {
  background: #f5f5f7;
}

.container {
  min-height: 100vh;
  padding-top: 20rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 102, 51, 0.3);
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-top: 24rpx;
}

.slogan {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
}

.version-badge {
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  background: #FFF0EB;
  border-radius: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #FF6633;
}

/* 功能特点 */
.features-section {
  margin: 0 24rpx 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
}

.feature-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 版本信息 */
.info-section {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #333;
}

.info-value {
  font-size: 28rpx;
  color: #999;
}

/* 操作按钮 */
.action-section {
  padding: 0 24rpx 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 12rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #333;
}

/* 版权 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}

.safe-area-bottom {
  height: 40rpx;
}
