<!-- 关于小程序页面 -->
<view class="page-sub">
  <!-- Logo 区域 -->
  <view class="s-card logo-card">
    <view class="logo-row">
      <view class="logo-icon-wrap">
        <text class="logo-icon">🍴</text>
      </view>
      <view class="logo-info">
        <text class="logo-name">美食探店</text>
        <text class="logo-desc">年轻人的美食天堂</text>
      </view>
    </view>
    <view class="version-row">
      <text class="version-label">当前版本</text>
      <text class="version-value">v{{version}}</text>
    </view>
  </view>

  <!-- 功能特点 -->
  <view class="sub-group">
    <view class="group-title">功能特点</view>
    <view class="feature-grid">
      <view class="feature-card" wx:for="{{features}}" wx:key="index">
        <text class="feature-emoji">{{item.iconText}}</text>
        <text class="feature-name">{{item.title}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 其他信息 -->
  <view class="sub-group">
    <view class="group-title">更多信息</view>
    <view class="s-card">
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>📅</text></view>
          <text class="s-title">构建号</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{buildNumber}}</text>
        </view>
      </view>
      <view class="s-cell s-cell-last">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>🕐</text></view>
          <text class="s-title">更新时间</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{updateTime}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作 -->
  <view class="sub-group">
    <view class="group-title">操作</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onCheckUpdate" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>🔄</text></view>
          <text class="s-title">检查更新</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onContact" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>📞</text></view>
          <text class="s-title">联系我们</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onLicense" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>📄</text></view>
          <text class="s-title">开源许可</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版权 -->
  <view class="copyright-area">
    <text class="copyright-text">© 2024 美食探店 All Rights Reserved</text>
  </view>

  <view class="safe-bottom"></view>
</view>
