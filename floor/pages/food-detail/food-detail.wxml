<!-- 美食详情页 - 大众点评风格 -->
<view class="page-container">
  <!-- 美食图片 -->
  <view class="food-images-section">
    <swiper class="food-swiper" indicator-dots="{{true}}" indicator-active-color="#FF6633" indicator-color="rgba(255,255,255,0.5)" autoplay="{{true}}" interval="{{4000}}" circular="{{true}}" bindchange="onImageChange">
      <swiper-item wx:for="{{food.images}}" wx:key="index">
        <image class="food-image" src="{{item}}" mode="aspectFill"></image>
      </swiper-item>
    </swiper>
    <view class="image-counter" wx:if="{{food.images && food.images.length > 1}}">
      <text>{{currentImageIndex + 1}}/{{food.images.length}}</text>
    </view>
    <!-- 返回按钮 -->
    <view class="nav-back" bindtap="onBackClick">
      <view class="nav-back-btn">←</view>
    </view>
    <!-- 分享/收藏 -->
    <view class="nav-actions">
      <view class="nav-action-btn" bindtap="onFavoriteClick">
        <text class="action-icon" style="font-size:36rpx;">{{isFavorite ? '❤️' : '🤍'}}</text>
      </view>
      <button class="nav-action-btn share-btn" open-type="share">
        <text class="action-icon -share-alt" style="font-size:36rpx;">↗</text>
      </button>
    </view>
  </view>

  <!-- 基本信息区域 -->
  <view class="info-section">
    <view class="price-row">
      <view class="price-box">
        <text class="price-symbol">¥</text>
        <text class="food-price">{{food.price}}</text>
        <view class="original-price" wx:if="{{food.originalPrice}}">
          <text class="orig-symbol">¥</text>
          <text class="orig-price">{{food.originalPrice}}</text>
        </view>
      </view>
      <view class="sold-info">
        <text class="sold-text">已售 {{food.sales || food.monthlySales || 0}} 份</text>
      </view>
    </view>
    <text class="food-name">{{food.name}}</text>
    <view class="tags-row" wx:if="{{food.tags}}">
      <view class="tag tag-hot" wx:if="{{food.tags.hot}}"><text class="-fire" style="margin-right:4rpx;">🔥</text>热销</view>
      <view class="tag tag-classic" wx:if="{{food.tags.classic}}"><text class="-star" style="margin-right:4rpx;">⭐</text>经典</view>
      <view class="tag tag-combo" wx:if="{{food.tags.combo}}"><text class="-utensils" style="margin-right:4rpx;">🍴</text>套餐</view>
      <view class="tag tag-healthy" wx:if="{{food.tags.healthy}}"><text class="-leaf" style="margin-right:4rpx;">●</text>营养</view>
    </view>
  </view>

  <!-- 评分信息 -->
  <view class="rating-section">
    <view class="rating-score">
      <text class="score-num">{{food.rating}}</text>
      <view class="score-stars">
        <text class="star" wx:for="{{5}}" wx:for-item="s" wx:key="*this">{{s <= food.rating ? '★' : '☆'}}</text>
      </view>
      <text class="review-count">{{food.reviews || 0}}条评价</text>
    </view>
    <view class="rating-info">
      <view class="info-item" wx:if="{{food.monthlySales}}">
        <text class="info-num">{{food.monthlySales}}</text>
        <text class="info-label">月销量</text>
      </view>
      <view class="info-item" wx:if="{{food.deliveryTime}}">
        <text class="info-num">{{food.deliveryTime}}</text>
        <text class="info-label">配送时间</text>
      </view>
      <view class="info-item">
        <text class="info-num">好评{{food.rating > 0 ? Math.round(food.rating / 5 * 100) : 95}}%</text>
        <text class="info-label">好评率</text>
      </view>
    </view>
  </view>

  <!-- 商品描述 -->
  <view class="desc-section">
    <view class="section-header">
      <text class="section-title">商品详情</text>
    </view>
    <text class="desc-text">{{food.description || '暂无描述'}}</text>
  </view>

  <!-- 用户评价 -->
  <view class="reviews-section" wx:if="{{reviews && reviews.length > 0}}">
    <view class="section-header">
      <text class="section-title">用户评价 ({{reviews.length}})</text>
      <text class="view-all" bindtap="onViewAllReviews">全部 ›</text>
    </view>
    <view class="review-list">
      <view class="review-card" wx:for="{{reviews}}" wx:key="id">
        <view class="review-top">
          <view class="reviewer-avatar">
            <text class="avatar-text">{{item.userName[0]}}</text>
          </view>
          <view class="reviewer-info">
            <text class="reviewer-name">{{item.userName}}</text>
            <view class="review-stars">
              <text class="star" wx:for="{{item.rating}}" wx:for-item="r" wx:key="*this">★</text>
            </view>
          </view>
          <text class="review-time">{{item.time}}</text>
        </view>
        <text class="review-content">{{item.content}}</text>
        <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
          <image class="review-img" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 空评价 -->
  <view class="empty-reviews" wx:if="{{!isLoading && (!reviews || reviews.length === 0)}}">
      <text class="-comments empty-icon" style="font-size:80rpx;">💬</text>
    <text class="empty-text">暂无评价，快来抢沙发</text>
  </view>

  <!-- 商家信息 -->
  <view class="store-card" bindtap="onStoreInfoClick">
    <view class="store-left">
      <image class="store-logo" src="{{store.logo}}" mode="aspectFill"></image>
      <view class="store-info">
        <text class="store-name">{{store.name}}</text>
        <view class="store-meta">
          <text class="store-rating">★ {{store.rating}}</text>
          <text class="store-divider">|</text>
          <text class="store-sales">月售{{store.monthlySales}}</text>
        </view>
        <view class="store-dist">
          <text>{{store.distance}} · {{store.deliveryTime}}</text>
        </view>
      </view>
    </view>
    <text class="store-arrow">›</text>
  </view>

  <!-- 底部占位 -->
  <view style="height: 140rpx;"></view>
</view>

<!-- 底部操作栏 -->
<view class="bottom-bar">
  <view class="bar-icons">
    <view class="bar-icon-item" bindtap="onFavoriteClick">
      <text class="bar-icon" style="font-size:40rpx;">{{isFavorite ? '❤️' : '🤍'}}</text>
      <text class="bar-label">{{isFavorite ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="bar-icon-item" bindtap="onCartClick">
      <text class="bar-icon -shopping-cart" style="font-size:40rpx;">🛒</text>
      <text class="bar-label">购物车</text>
      <view class="bar-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
  </view>
  <view class="bar-btns">
    <button class="bar-btn add-cart" bindtap="onAddToCart">加入购物车</button>
    <button class="bar-btn buy-now" bindtap="onBuyNow">立即购买</button>
  </view>
</view>

<!-- 购物车详情弹窗 -->
<view class="cart-popup-mask" wx:if="{{showCartPopup}}" bindtap="hideCartPopup"></view>
<view class="cart-popup {{showCartPopup ? 'cart-popup-show' : ''}}">
  <view class="cart-popup-header">
    <text class="cart-popup-title">购物车</text>
    <text class="cart-popup-count" wx:if="{{cartPopupItems.length > 0}}">共{{cartPopupCount}}件</text>
    <text class="cart-popup-clear" wx:if="{{cartPopupItems.length > 0}}" bindtap="clearCart">清空</text>
  </view>
  <scroll-view class="cart-popup-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="cart-popup-empty" wx:if="{{cartPopupItems.length === 0}}">
      <text class="cart-empty-icon -shopping-cart" style="font-size:80rpx;">🛒</text>
      <text class="cart-empty-text">购物车是空的</text>
    </view>
    <view class="cart-popup-item" wx:for="{{cartPopupItems}}" wx:key="foodId">
      <image class="cart-item-img" src="{{item.image}}" mode="aspectFill"></image>
      <view class="cart-item-info">
        <text class="cart-item-name">{{item.name}}</text>
        <text class="cart-item-price">¥{{item.price}}</text>
      </view>
      <view class="cart-item-right">
        <text class="cart-item-subtotal">¥{{item.subtotal}}</text>
        <view class="cart-item-qty">
          <view class="qty-btn" bindtap="onCartItemMinus" data-index="{{index}}">-</view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn qty-plus" bindtap="onCartItemPlus" data-index="{{index}}">+</view>
        </view>
      </view>
    </view>
  </scroll-view>
  <view class="cart-popup-footer" wx:if="{{cartPopupItems.length > 0}}">
    <view class="cart-popup-total">
      <text class="cart-total-label">合计</text>
      <text class="cart-total-price">¥{{cartPopupTotal}}</text>
    </view>
    <view class="cart-popup-go" bindtap="goToCart">去购物车</view>
  </view>
</view>
