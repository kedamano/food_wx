/* 美食详情页 - 大众点评风格 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page-container {
  padding-bottom: 0;
}

/* 图片区域 */
.food-images-section {
  position: relative;
  height: 560rpx;
  overflow: hidden;
}

.food-swiper {
  height: 100%;
}

.food-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 浮动导航按钮 */
.nav-back {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  z-index: 10;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  backdrop-filter: blur(10px);
}

.nav-actions {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
  display: flex;
  gap: 16rpx;
}

.nav-action-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  border: none;
  padding: 0;
  line-height: 1;
}

.nav-action-btn::after {
  border: none;
}

.share-btn {
  margin: 0;
}

.action-icon {
  font-size: 32rpx;
}

/* 基本信息 */
.info-section {
  background: #fff;
  padding: 28rpx 32rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6633;
  font-weight: 700;
}

.food-price {
  font-size: 52rpx;
  color: #FF6633;
  font-weight: 800;
  line-height: 1;
  margin-right: 12rpx;
}

.original-price {
  display: flex;
  align-items: baseline;
}

.orig-symbol {
  font-size: 22rpx;
  color: #999;
}

.orig-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.sold-info {
  margin-bottom: 8rpx;
}

.sold-text {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.food-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
  display: block;
  margin-bottom: 16rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tag-hot {
  background: rgba(255, 102, 51, 0.1);
  color: #FF6633;
}

.tag-classic {
  background: rgba(255, 193, 7, 0.1);
  color: #e6a700;
}

.tag-combo {
  background: rgba(78, 205, 196, 0.1);
  color: #3baa9f;
}

.tag-healthy {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

/* 评分区域 */
.rating-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
}

.rating-score {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6633;
}

.score-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #FF6633;
}

.review-count {
  font-size: 24rpx;
  color: #999;
}

.rating-info {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
}

/* 描述区域 */
.desc-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.view-all {
  font-size: 26rpx;
  color: #999;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

/* 评价区域 */
.reviews-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-card {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.review-top {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reviewer-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.reviewer-info {
  flex: 1;
}

.reviewer-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.review-stars {
  display: flex;
  gap: 2rpx;
}

.review-stars .star {
  font-size: 20rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.review-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.review-images {
  display: flex;
  gap: 12rpx;
}

.review-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.empty-reviews {
  background: #fff;
  margin-top: 16rpx;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 商家卡片 */
.store-card {
  background: #fff;
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.store-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.store-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.store-info {
  flex: 1;
}

.store-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.store-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.store-rating {
  font-size: 24rpx;
  color: #FF6633;
  font-weight: 600;
}

.store-divider {
  color: #ddd;
  font-size: 20rpx;
}

.store-sales {
  font-size: 22rpx;
  color: #999;
}

.store-dist {
  font-size: 22rpx;
  color: #999;
}

.store-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bar-icons {
  display: flex;
  gap: 32rpx;
  margin-right: 24rpx;
}

.bar-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.bar-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
}

.bar-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

.bar-btns {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.bar-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
}

.bar-btn::after {
  border: none;
}

.add-cart {
  background: linear-gradient(135deg, #FFaa55, #FF8833);
  color: #fff;
}

.buy-now {
  background: linear-gradient(135deg, #FF6633, #ee4422);
  color: #fff;
}

/* 购物车弹窗 */
.cart-popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.cart-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.cart-popup-show {
  transform: translateY(0);
}

.cart-popup-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.cart-popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.cart-popup-count {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.cart-popup-clear {
  font-size: 24rpx;
  color: #FF3B30;
  padding: 8rpx 16rpx;
}

.cart-popup-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 32rpx;
}

.cart-popup-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.cart-empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.cart-empty-text {
  font-size: 28rpx;
  color: #999;
}

.cart-popup-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-popup-item:last-child {
  border-bottom: none;
}

.cart-item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.cart-item-price {
  font-size: 24rpx;
  color: #999;
}

.cart-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.cart-item-subtotal {
  font-size: 28rpx;
  color: #FF6633;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.cart-item-qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 1rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  background: #fff;
}

.qty-btn.qty-plus {
  background: #FF6633;
  border-color: #FF6633;
  color: #fff;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

.cart-popup-footer {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.cart-popup-total {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.cart-total-label {
  font-size: 26rpx;
  color: #666;
}

.cart-total-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF6633;
}

.cart-popup-go {
  background: linear-gradient(135deg, #FF6633, #ee4422);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
}
