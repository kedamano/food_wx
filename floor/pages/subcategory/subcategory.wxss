/* 子分类页面样式 */
page {
  background-color: #f5f5f5;
}

.scrollarea {
  height: 100vh;
  padding-bottom: 120rpx;
}

/* 头部导航 */
.header-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #00d04e, #00b84a);
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left,
.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
}

/* 美食列表 */
.food-section {
  background-color: white;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.food-list {
  display: flex;
  flex-direction: column;
}

.food-item {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.food-item:last-child {
  border-bottom: none;
}

.food-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.food-img {
  width: 100%;
  height: 100%;
}

.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.food-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.food-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: auto;
}

.food-price {
  font-size: 34rpx;
  color: #ff6b00;
  font-weight: bold;
}

.food-sales {
  font-size: 24rpx;
  color: #999;
}

.rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating .fa-star {
  color: #ff9500;
  font-size: 20rpx;
}

.rating-text {
  font-size: 22rpx;
  color: #ff9500;
}

.add-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d04e, #00b84a);
  color: white;
  font-size: 44rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 208, 78, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #00d04e;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

/* 底部购物车栏 */
.bottom-cart {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #333;
  color: white;
  z-index: 1000;
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-icon-wrapper {
  position: relative;
  font-size: 48rpx;
}

.cart-count {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  background-color: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.cart-total {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b00;
}

.settle-btn {
  background: linear-gradient(135deg, #00d04e, #00b84a);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  border: none;
}
