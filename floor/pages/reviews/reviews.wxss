/* pages/reviews/reviews.wxss */
/* 用户评价 - 现代化CSS */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部 */
.header-section {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.review-stats {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 评价列表 */
.review-list {
  padding-bottom: 20rpx;
}

.review-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s ease;
}

.review-card:active {
  transform: scale(0.98);
}

/* 商家信息 */
.store-section {
  padding: 30rpx;
  background: #F9F9F9;
}

.store-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.store-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.store-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.review-time {
  margin-left: auto;
  font-size: 24rpx;
  color: #999999;
}

.order-info {
  background: #FFFFFF;
  padding: 16rpx;
  border-radius: 12rpx;
}

.order-foods {
  font-size: 24rpx;
  color: #666666;
}

/* 评价内容 */
.review-section {
  padding: 30rpx;
}

.review-rating {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  margin-right: 16rpx;
}

.star {
  font-size: 32rpx;
  margin-right: 4rpx;
}

.rating-text {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 600;
}

.review-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

/* 评价图片 */
.review-images {
  padding: 0 30rpx 30rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

/* 操作按钮 */
.action-section {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  border: none;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.edit {
  background: #E8F5E8;
  color: #4CAF50;
}

.action-btn.delete {
  background: #FFE8E8;
  color: #FF6B6B;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  color: #CCCCCC;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}