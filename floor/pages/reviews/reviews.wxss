/* pages/reviews/reviews.wxss */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
}

/* ===== 头部评分概览 ===== */
.header-section {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  padding: 40rpx 30rpx 36rpx;
  position: relative;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.back-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.header-body {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avg-score-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 140rpx;
}

.avg-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.avg-stars {
  display: flex;
  margin: 10rpx 0 8rpx;
}

.avg-stars .star {
  font-size: 26rpx;
  color: #FFE066;
}

.total-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

/* 评分条 */
.score-bars {
  flex: 1;
}

.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.bar-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  width: 50rpx;
}

.bar-track {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 5rpx;
  overflow: hidden;
  margin: 0 12rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s;
}

.bar-good { background: #fff; }
.bar-mid  { background: rgba(255,255,255,0.7); }
.bar-bad  { background: rgba(255,255,255,0.45); }

.bar-count {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  width: 30rpx;
  text-align: right;
}

.img-tag {
  margin-top: 14rpx;
}

.img-tag-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}

/* ===== 筛选 Tab ===== */
.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.filter-tab.active {
  color: #FF6633;
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF6633;
  border-radius: 2rpx;
}

/* ===== 评价列表 ===== */
.review-list {
  padding: 20rpx;
}

.review-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.review-top {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FF6633;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  display: block;
}

.stars-row {
  display: flex;
}

.star-filled {
  font-size: 26rpx;
  color: #FF9500;
  margin-right: 2rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.review-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 16rpx;
  display: block;
}

/* 评价图片 */
.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.review-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

/* ===== 空/加载状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #aaa;
}

.safe-area-bottom {
  height: 50rpx;
}
