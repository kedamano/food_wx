<!-- 全部评价页面 -->
<scroll-view class="container" scroll-y>
  <!-- 头部：评分概览 -->
  <view class="header-section">
    <view class="back-btn" bindtap="onBackClick">
      <text class="back-icon">←</text>
    </view>
    <view class="header-body">
      <view class="avg-score-block">
        <text class="avg-score">{{reviewStats.avgRating}}</text>
        <view class="avg-stars">
          <text class="star" wx:for="{{5}}" wx:for-item="s" wx:key="*this">{{s <= reviewStats.avgRating ? '★' : '☆'}}</text>
        </view>
        <text class="total-label">共{{reviewStats.total}}条评价</text>
      </view>
      <view class="score-bars">
        <view class="bar-row">
          <text class="bar-label">好评</text>
          <view class="bar-track">
            <view class="bar-fill bar-good" style="width:{{reviewStats.total > 0 ? reviewStats.fiveStarCount / reviewStats.total * 100 : 0}}%"></view>
          </view>
          <text class="bar-count">{{reviewStats.fiveStarCount}}</text>
        </view>
        <view class="bar-row">
          <text class="bar-label">中评</text>
          <view class="bar-track">
            <view class="bar-fill bar-mid" style="width:{{reviewStats.total > 0 ? reviewStats.fourStarCount / reviewStats.total * 100 : 0}}%"></view>
          </view>
          <text class="bar-count">{{reviewStats.fourStarCount}}</text>
        </view>
        <view class="bar-row">
          <text class="bar-label">差评</text>
          <view class="bar-track">
            <view class="bar-fill bar-bad" style="width:{{reviewStats.total > 0 ? reviewStats.threeStarCount / reviewStats.total * 100 : 0}}%"></view>
          </view>
          <text class="bar-count">{{reviewStats.threeStarCount}}</text>
        </view>
        <view class="img-tag" wx:if="{{reviewStats.withImage > 0}}">
          <text class="img-tag-text"><text class="-camera" style="margin-right:8rpx;">📷</text>{{reviewStats.withImage}}条有图</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选 Tab -->
  <view class="filter-tabs">
    <view
      class="filter-tab {{currentFilter === item.key ? 'active' : ''}}"
      wx:for="{{filterTabs}}" wx:key="key"
      bindtap="onFilterChange"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 评价列表 -->
  <view class="review-list" wx:if="{{reviews.length > 0}}">
    <view class="review-card" wx:for="{{reviews}}" wx:key="id">
      <view class="review-top">
        <view class="avatar">
          <text class="avatar-text">{{item.avatarText}}</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{item.userName}}</text>
          <view class="stars-row">
            <text class="star-filled" wx:for="{{item.stars}}" wx:for-item="s" wx:key="*this">★</text>
          </view>
        </view>
        <text class="review-time">{{item.time}}</text>
      </view>
      <text class="review-content">{{item.content}}</text>
      <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
        <image
          class="review-img"
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          src="{{img}}"
          mode="aspectFill"
        ></image>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="empty-state" wx:if="{{isLoading}}">
    <text class="empty-title">加载中...</text>
  </view>

  <!-- 无评价 -->
  <view class="empty-state" wx:if="{{!isLoading && reviews.length === 0}}">
    <text class="-comments empty-icon" style="font-size:80rpx;">💬</text>
    <text class="empty-title">暂无评价</text>
    <text class="empty-desc">快来抢沙发吧~</text>
  </view>

  <view class="safe-area-bottom"></view>
</scroll-view>
