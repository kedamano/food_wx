/* 意见反馈页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx 20rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
}

.header-placeholder {
  width: 80rpx;
}

/* 区块 */
.section {
  margin: 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

/* 反馈类型 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.type-item.selected {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.type-name {
  font-size: 24rpx;
  color: #666;
}

.type-item.selected .type-name {
  color: #4CAF50;
}

/* 反馈内容 */
.content-box {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.content-input {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.char-count {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* 上传图片 */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

/* 联系方式 */
.contact-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 30rpx 20rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  background: #ccc;
}

.history-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.history-text {
  font-size: 26rpx;
  color: #666;
}

/* 提示 */
.tips {
  padding: 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  line-height: 1.8;
}
