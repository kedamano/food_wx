/* 意见反馈页面 - 统一设置风格 */
page {
  background: #f5f5f5;
}

.page-sub {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- 分组 ---------- */
.sub-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片 ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.s-cell-hover {
  background: #fafafa;
}

/* ---------- 反馈类型选择 ---------- */
.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 0 24rpx;
  padding: 4rpx 0;
}

.type-chip {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 40rpx;
  border: 2rpx solid #eee;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.type-chip.active {
  background: rgba(255, 102, 51, 0.06);
  border-color: #FF6633;
}

.type-chip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.type-chip-name {
  font-size: 26rpx;
  color: #555;
}

.type-chip.active .type-chip-name {
  color: #FF6633;
  font-weight: 500;
}

/* ---------- 反馈内容文本框 ---------- */
.textarea-card {
  padding: 24rpx;
}

.fb-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.textarea-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.char-count {
  font-size: 24rpx;
  color: #ccc;
}

/* ---------- 图片上传 ---------- */
.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 0 24rpx;
  padding: 4rpx 0;
}

.image-thumb {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.thumb-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.thumb-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.del-icon {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.add-plus {
  font-size: 52rpx;
  color: #ccc;
  line-height: 1;
}

.add-label {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* ---------- 联系方式输入 ---------- */
.input-cell {
  padding: 24rpx 32rpx;
}

.fb-input {
  font-size: 28rpx;
  color: #333;
}

/* ---------- 提交按钮 ---------- */
.btn-area {
  padding: 8rpx 24rpx 16rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #fff;
}

/* ---------- 提示区域 ---------- */
.tip-section {
  margin-bottom: 16rpx;
}

.tip-card {
  padding: 24rpx 32rpx;
}

.tip-header {
  margin-bottom: 16rpx;
}

.tip-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tip-list {
  display: flex;
  flex-direction: column;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.tip-row:last-child {
  margin-bottom: 0;
}

.tip-dot {
  font-size: 28rpx;
  color: #ccc;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* ---------- 查看历史 ---------- */
.history-link {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx 8rpx;
}

.history-text {
  font-size: 26rpx;
  color: #FF6633;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
