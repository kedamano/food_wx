/* 意见反馈页面样式 */
page {
  background: #f5f5f7;
}

.container {
  min-height: 100vh;
  padding-top: 20rpx;
}

/* 区块 */
.section {
  margin: 0 24rpx 20rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

/* 反馈类型 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.type-item.selected {
  background: #FFF0EB;
  border-color: #FF6633;
}

.type-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 24rpx;
  color: #666;
}

.type-item.selected .type-name {
  color: #FF6633;
}

/* 反馈内容 */
.content-box {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.content-input {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* 上传图片 */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* 联系方式 */
.contact-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 10rpx 24rpx 0;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  background: #ccc;
}

.history-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding-bottom: 10rpx;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.history-text {
  font-size: 26rpx;
  color: #666;
}

/* 提示 */
.tips {
  padding: 20rpx 30rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  line-height: 1.8;
}

.safe-area-bottom {
  height: 40rpx;
}
