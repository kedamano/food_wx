/**index.wxss - 大众点评风格首页样式**/

/* 页面 */
.page-index {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  padding-top: calc(12rpx + env(safe-area-inset-top));
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
  gap: 16rpx;
}

/* 定位 */
.location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  padding: 8rpx 0;
}

.location-icon {
  font-size: 28rpx;
  color: var(--primary);
}

.location-text {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  max-width: 100rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 搜索栏 */
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  gap: 12rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 26rpx;
  color: var(--text-light);
}

.search-placeholder {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

/* 扫码按钮 */
.scan-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-icon {
  font-size: 36rpx;
  color: var(--text-secondary);
}

/* 滚动区 */
.main-scroll {
  flex: 1;
  height: 0;
}

/* 轮播图 */
.banner-wrap {
  padding: 20rpx 24rpx 0;
}

.banner-swiper {
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 28rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.55));
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 功能宫格 */
.channel-grid {
  padding: 28rpx 12rpx;
}

.grid-row {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.grid-icon .fa {
  font-size: 40rpx;
}

.grid-icon-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.grid-text {
  font-size: 22rpx;
  color: var(--text-main);
}

/* 限时特惠 */
.promo-card {
  padding: 24rpx;
}

.promo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.promo-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.promo-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.countdown {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.countdown-num {
  background: var(--text-main);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  min-width: 36rpx;
  text-align: center;
}

.countdown-colon {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
}

.promo-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.promo-scroll {
  white-space: nowrap;
}

.promo-list {
  display: inline-flex;
  gap: 20rpx;
}

.promo-item {
  width: 220rpx;
  flex-shrink: 0;
}

.promo-img-wrap {
  width: 220rpx;
  height: 220rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
  margin-bottom: 12rpx;
}

.promo-img {
  width: 100%;
  height: 100%;
}

.promo-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: var(--primary);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 0 0 16rpx 0;
}

.promo-info {
  white-space: normal;
}

.promo-name {
  font-size: 26rpx;
  color: var(--text-main);
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.promo-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.promo-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.promo-origin-price {
  font-size: 22rpx;
  color: var(--text-light);
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 猜你喜欢 */
.recommend-section {
  padding: 0 0 40rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 0;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  font-size: 24rpx;
  color: var(--text-light);
  padding: 6rpx 0;
  position: relative;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 商家列表 */
.store-list {
  padding: 0 24rpx;
}

.store-card {
  margin: 16rpx 0;
  padding: 0;
}

.store-card-img {
  width: 100%;
  height: 340rpx;
  position: relative;
  overflow: hidden;
}

.store-img {
  width: 100%;
  height: 100%;
}

.store-img-placeholder {
  width: 100%;
  height: 100%;
  background: #EAEAEA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-img-placeholder .fa {
  font-size: 80rpx;
  color: var(--text-placeholder);
}

.store-rank-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.55);
  color: #FFD700;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}

.store-card-body {
  padding: 20rpx 24rpx 24rpx;
}

.store-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.store-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.3;
}

.store-rating-badge {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  flex-shrink: 0;
  background: var(--primary);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.store-rating-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.store-rating-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
}

/* 评价信息 */
.store-card-review {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.review-tag {
  background: rgba(255, 184, 0, 0.1);
  color: var(--orange);
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}

.review-count {
  font-size: 22rpx;
  color: var(--text-light);
}

.store-distance {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: auto;
}

/* 底部信息 */
.store-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.store-price-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.store-avg-price {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 500;
}

.store-delivery {
  font-size: 22rpx;
  color: var(--text-light);
}

.store-tags {
  display: flex;
  gap: 8rpx;
}

.store-tag {
  font-size: 20rpx;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
}

/* 优惠信息 */
.store-card-deals {
  padding-top: 14rpx;
  border-top: 1rpx solid var(--divider);
}

.deal-tag {
  background: rgba(255, 102, 51, 0.06);
  color: var(--primary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(255, 102, 51, 0.15);
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-light);
}
