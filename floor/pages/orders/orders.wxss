/* 订单管理页面 - 现代化CSS */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.header-section {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.2);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.search-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.status-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 10rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #FF6633;
}

.tab-text {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.tab-item.active .tab-text {
  color: #FFFFFF;
  font-weight: 500;
}

.tab-badge {
  font-size: 20rpx;
  color: #FF6B6B;
  background: #FFE8E8;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  min-width: 30rpx;
  text-align: center;
}

.tab-item.active .tab-badge {
  background: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
}

.order-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s ease;
}

.order-card:active {
  transform: scale(0.98);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.order-status.pending {
  background: #FFF0EB;
  color: #FF6633;
}

.order-status.preparing {
  background: #E8F4FF;
  color: #2196F3;
}

.order-status.delivering {
  background: #FFF3E0;
  color: #FF9800;
}

.order-status.completed {
  background: #F5F5F5;
  color: #666666;
}

.order-time {
  font-size: 22rpx;
  color: #999999;
}

.store-section {
  padding: 20rpx 30rpx;
  background: #F9F9F9;
}

.store-info {
  display: flex;
  align-items: center;
}

.store-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.store-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.items-section {
  padding: 20rpx 30rpx;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.food-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.food-icon {
  font-size: 32rpx;
}

.item-details {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.item-quantity {
  font-size: 24rpx;
  color: #999999;
  margin: 0 16rpx;
}

.item-price {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.amount-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
  background: #F9F9F9;
}

.amount-label {
  font-size: 26rpx;
  color: #666666;
}

.amount-value {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.action-section {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  border: none;
}

.btn:active {
  transform: scale(0.95);
}

.btn-primary {
  background: #FF6633;
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}

.btn-outline {
  background: transparent;
  color: #FF6633;
  border: 2rpx solid #FF6633;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  color: #CCCCCC;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
  text-align: center;
}

.safe-area-bottom {
  height: 40rpx;
}