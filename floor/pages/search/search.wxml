<!-- 搜索页 -->
<view class="page-search">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-input-wrap">
      <text class="-search search-icon">🔍</text>
      <input class="search-input" placeholder="搜索美食、商家" 
             value="{{keyword}}" focus="{{true}}" 
             bindinput="onInput" bindconfirm="onSearch" confirm-type="search" />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="onClear">
        <text class="-circle-xmark">✕</text>
      </text>
    </view>
    <text class="cancel-btn" bindtap="onCancel">取消</text>
  </view>

  <!-- 搜索历史 -->
  <view class="history-section" wx:if="{{!hasSearched && searchHistory.length > 0}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-history" bindtap="onClearHistory">
        <text class="-trash-can">🗑</text> 清空
      </text>
    </view>
    <view class="history-tags">
      <text class="history-tag" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onHistoryTap">{{item}}</text>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot-section" wx:if="{{!hasSearched}}">
    <view class="section-header">
      <text class="section-title">热门搜索</text>
    </view>
    <view class="hot-tags">
      <text class="hot-tag" wx:for="{{hotSearches}}" wx:key="*this" bindtap="onHotTap">{{item}}</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-section" wx:if="{{hasSearched}}">
    <!-- Tab切换 -->
    <view class="result-tabs">
      <text class="result-tab {{activeTab === 'food' ? 'active' : ''}}" bindtap="switchTab" data-tab="food">美食</text>
      <text class="result-tab {{activeTab === 'store' ? 'active' : ''}}" bindtap="switchTab" data-tab="store">商家</text>
    </view>

    <!-- 美食结果 -->
    <scroll-view class="result-scroll" scroll-y wx:if="{{activeTab === 'food'}}">
      <view class="result-list" wx:if="{{foodResults.length > 0}}">
        <view class="food-result-item" wx:for="{{foodResults}}" wx:key="id" bindtap="onFoodTap" data-id="{{item.id}}">
          <image class="food-result-img" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}"></image>
          <view class="food-result-info">
            <text class="food-result-name">{{item.name}}</text>
            <view class="food-result-meta">
              <text class="food-result-rating" wx:if="{{item.rating}}">★ {{item.rating}}</text>
              <text class="food-result-sales" wx:if="{{item.sales}}">月售{{item.sales}}</text>
            </view>
            <view class="food-result-bottom">
              <view class="food-result-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <text class="food-result-category" wx:if="{{item.categoryName}}">{{item.categoryName}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-result" wx:else>
        <text class="-search">🔍</text>
        <text class="empty-text">未找到相关美食</text>
        <text class="empty-sub">换个关键词试试</text>
      </view>
    </scroll-view>

    <!-- 商家结果 -->
    <scroll-view class="result-scroll" scroll-y wx:if="{{activeTab === 'store'}}">
      <view class="result-list" wx:if="{{storeResults.length > 0}}">
        <view class="store-result-item" wx:for="{{storeResults}}" wx:key="id" bindtap="onStoreTap" data-id="{{item.id}}">
          <image class="store-result-img" src="{{item.logo || item.banner}}" mode="aspectFill" wx:if="{{item.logo || item.banner}}"></image>
          <view class="store-result-placeholder" wx:else><text class="-store">🏪</text></view>
          <view class="store-result-info">
            <text class="store-result-name">{{item.name}}</text>
            <view class="store-result-meta">
              <text class="store-result-rating" wx:if="{{item.rating}}">★ {{item.rating}}</text>
              <text class="store-result-distance" wx:if="{{item.distance}}">{{item.distance}}</text>
            </view>
            <text class="store-result-price">¥{{item.priceLevel || item.price || '30'}}/人</text>
          </view>
        </view>
      </view>
      <view class="empty-result" wx:else>
        <text class="-search">🔍</text>
        <text class="empty-text">未找到相关商家</text>
        <text class="empty-sub">换个关键词试试</text>
      </view>
    </scroll-view>
  </view>
</view>
