<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image class="logo" src="/images/login_wx.png" mode="aspectFit"></image>
    <text class="app-name">美食小程序</text>
    <text class="app-slogan">发现美味，享受生活</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <form bindsubmit="onLoginSubmit">
      <!-- 用户名/手机号输入 -->
      <view class="form-item">
        <view class="item-label">
          <text class="fa fa-user label-icon"></text>
          <text class="label-text">用户名</text>
        </view>
        <input 
          class="item-input" 
          name="username"
          placeholder="请输入用户名或手机号"
          placeholder-class="input-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>

      <!-- 密码输入 -->
      <view class="form-item">
        <view class="item-label">
          <text class="label-icon">🔒</text>
          <text class="label-text">密码</text>
        </view>
        <input 
          class="item-input" 
          name="password"
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <text class="fa {{showPassword ? 'fa-eye-slash' : 'fa-eye'}} password-toggle" bindtap="onTogglePassword"></text>
      </view>

      <!-- 记住我 & 忘记密码 -->
      <view class="form-options">
        <label class="remember-me">
          <checkbox class="checkbox" value="{{rememberMe}}" bindtap="onToggleRemember" />
          <text class="checkbox-label">记住我</text>
        </label>
        <text class="forgot-password" bindtap="onForgotPassword">忘记密码？</text>
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-btn" 
        form-type="submit"
        loading="{{isLoading}}"
        disabled="{{isLoading}}"
      >
        {{isLoading ? '登录中...' : '登录'}}
      </button>
    </form>

    <!-- 错误提示 -->
    <text class="error-message" wx:if="{{errorMessage}}">{{errorMessage}}</text>

    <!-- 其他登录方式 -->
    <view class="other-login">
      <text class="divider-text">其他登录方式</text>
      <view class="social-login">
        <button class="social-btn wechat" bindtap="onWeChatLogin">
          <text class="fa fa-weixin social-icon"></text>
          <text class="social-text">微信</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 注册链接 -->
  <view class="register-link">
    <text class="link-text">还没有账号？</text>
    <text class="link" bindtap="onGoToRegister">立即注册</text>
  </view>
</view>