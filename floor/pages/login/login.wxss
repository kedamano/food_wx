/* 容器样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  background-color: #ffffff;
  padding: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.item-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.item-input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 24rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.item-input:focus {
  border-color: #4CAF50;
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.1);
}

.input-placeholder {
  color: #999999;
  font-size: 28rpx;
}

/* 密码输入框特殊样式 */
.form-item:last-child {
  position: relative;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 68rpx;
  font-size: 36rpx;
  cursor: pointer;
  user-select: none;
}

/* 表单选项 */
.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  font-size: 26rpx;
}

.remember-me {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.checkbox-label {
  color: #666666;
}

.forgot-password {
  color: #4CAF50;
  cursor: pointer;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}

.login-btn:active {
  transform: translateY(0);
}

.login-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

/* 错误提示 */
.error-message {
  display: block;
  color: #ff6b6b;
  font-size: 26rpx;
  text-align: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 16rpx;
}

/* 其他登录方式 */
.other-login {
  margin-top: 48rpx;
  text-align: center;
}

.divider-text {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
  position: relative;
}

.divider-text::before,
.divider-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 80rpx;
  height: 2rpx;
  background: #e8e8e8;
}

.divider-text::before {
  left: 0;
  transform: translateY(-50%);
}

.divider-text::after {
  right: 0;
  transform: translateY(-50%);
}

.social-login {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.social-btn {
  flex: 1;
  max-width: 200rpx;
  height: 72rpx;
  background: #f5f7fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.social-btn:hover {
  background: #e8f5e8;
  border-color: #4CAF50;
}

.social-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.social-text {
  font-size: 24rpx;
  color: #666666;
}

.wechat {
  background: #07c160;
  border-color: #07c160;
}

.wechat .social-text {
  color: #ffffff;
}

/* 注册链接 */
.register-link {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.link-text {
  color: rgba(255, 255, 255, 0.9);
}

.link {
  color: #ffffff;
  font-weight: 500;
  margin-left: 8rpx;
  cursor: pointer;
  text-decoration: underline;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .container {
    padding: 0 30rpx;
  }
  
  .login-form {
    padding: 36rpx 30rpx;
  }
  
  .logo {
    width: 140rpx;
    height: 140rpx;
  }
  
  .app-name {
    font-size: 40rpx;
  }
}

@media (max-width: 480px) {
  .container {
    padding: 0 20rpx;
  }
  
  .login-form {
    padding: 28rpx 20rpx;
  }
  
  .logo {
    width: 120rpx;
    height: 120rpx;
  }
  
  .app-name {
    font-size: 36rpx;
  }
  
  .social-btn {
    max-width: 160rpx;
    height: 64rpx;
  }
}