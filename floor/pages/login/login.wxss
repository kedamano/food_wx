/* 登录页 - 大众点评橙红风格 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 50%, #FFaa77 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰圆圈 */
.container::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.container::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  margin-bottom: 28rpx;
  background-color: #ffffff;
  padding: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.12);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20px);
}

.form-item {
  margin-bottom: 28rpx;
}

.item-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.item-input {
  width: 100%;
  height: 96rpx;
  background: #f8f8f8;
  border: 2rpx solid #eee;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}

.item-input:focus {
  border-color: #FF6633;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 102, 51, 0.08);
}

.input-placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.password-toggle {
  position: absolute;
  right: 48rpx;
  font-size: 36rpx;
  color: #999;
}

/* 选项 */
.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.remember-me {
  display: flex;
  align-items: center;
}

.checkbox {
  transform: scale(0.8);
  margin-right: 8rpx;
}

.checkbox-label {
  font-size: 26rpx;
  color: #666;
}

.forgot-password {
  font-size: 26rpx;
  color: #FF6633;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 51, 0.35);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
}

.login-btn:disabled {
  opacity: 0.6;
}

/* 错误 */
.error-message {
  display: block;
  color: #FF3B30;
  font-size: 26rpx;
  text-align: center;
  margin-top: 20rpx;
  padding: 12rpx;
  background: rgba(255, 59, 48, 0.08);
  border-radius: 12rpx;
}

/* 其他登录 */
.other-login {
  margin-top: 40rpx;
  text-align: center;
}

.divider-text {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 28rpx;
}

.divider-text::before,
.divider-text::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider-text::before {
  margin-right: 24rpx;
}

.divider-text::after {
  margin-left: 24rpx;
}

.social-login {
  display: flex;
  justify-content: center;
}

.social-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  background: transparent;
}

.social-btn::after {
  border: none;
}

.social-icon {
  font-size: 44rpx;
  margin: 0;
}

.wechat {
  background: #07C160;
}

.wechat .social-icon {
  color: #fff;
}

/* 注册链接 */
.register-link {
  margin-top: 48rpx;
  margin-bottom: 60rpx;
  text-align: center;
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.link-text {
  color: rgba(255, 255, 255, 0.85);
}

.link {
  color: #fff;
  font-weight: 600;
  margin-left: 8rpx;
}
