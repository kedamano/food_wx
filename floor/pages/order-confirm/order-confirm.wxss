/* pages/order-confirm/order-confirm.wxss */
page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  min-height: 100vh;
}

.scrollarea {
  height: calc(100vh - 60px);
  background-color: #F8F9FA;
}

/* 头部导航 */
.header-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  border-bottom: 1px solid #E9ECEF;
  transition: all 0.3s ease;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s ease;
}

.nav-left:hover, .nav-right:hover {
  background: #F8F9FA;
}

.nav-left:active, .nav-right:active {
  transform: scale(0.9);
}

.back-icon, .home-icon {
  font-size: 24px;
  color: #FF6633;
  transition: all 0.3s ease;
}

.nav-title {
  font-size: 20px;
  font-weight: 600;
  color: #212529;
}

/* 收货地址 */
.address-section {
  background: #FFFFFF;
  margin: 20px 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  cursor: pointer;
  transition: all 0.3s ease;
}

.address-section:active {
  transform: translateY(2px);
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.05);
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #212529;
}

.change-text {
  font-size: 14px;
  color: #FF6633;
  font-weight: 500;
}

.address-content {
  padding: 12px 0;
}

.address-info {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.user-name {
  font-size: 16px;
  font-weight: 500;
  color: #212529;
  margin-right: 12px;
}

.user-phone {
  font-size: 14px;
  color: #6C757D;
}

.address-detail {
  font-size: 14px;
  color: #6C757D;
  line-height: 1.5;
}

.address-empty {
  padding: 20px;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  color: #9E9E9E;
}

/* 商家信息 */
.store-section {
  background: #FFFFFF;
  margin: 0 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.store-info {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.store-icon {
  font-size: 24px;
  margin-right: 12px;
  color: #FF6633;
}

.store-name {
  font-size: 17px;
  font-weight: 600;
  color: #212529;
}

.delivery-info, .delivery-time {
  display: flex;
  margin-bottom: 8px;
}

.delivery-label, .time-label {
  font-size: 14px;
  color: #6C757D;
  margin-right: 8px;
}

.delivery-value, .time-value {
  font-size: 14px;
  color: #212529;
  font-weight: 500;
}

/* 商品列表 */
.items-section {
  background: #FFFFFF;
  margin: 0 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.item-list {
  margin-top: 12px;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #E9ECEF;
  transition: all 0.3s ease;
}

.item-row:hover {
  background: #F8F9FA;
  margin: 0 -12px;
  padding: 12px;
}

.item-row:last-child {
  border-bottom: none;
}

.item-image {
  width: 60px;
  height: 60px;
  margin-right: 12px;
  background: linear-gradient(45deg, #FF6633 0%, #FF8855 100%);
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.food-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.food-icon {
  font-size: 24px;
  color: #FFFFFF;
  opacity: 0.8;
}

.item-details {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 14px;
  font-weight: 500;
  color: #212529;
  margin-bottom: 4px;
}

.item-quantity {
  font-size: 12px;
  color: #6C757D;
}

.item-price {
  font-size: 16px;
  font-weight: 600;
  color: #FF6633;
}

/* 费用明细 */
.cost-section {
  background: #FFFFFF;
  margin: 0 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.cost-details {
  margin-top: 12px;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.cost-label {
  font-size: 14px;
  color: #6C757D;
}

.cost-value {
  font-size: 14px;
  color: #212529;
}

.cost-value.discount {
  color: #FF6633;
}

.cost-row.total {
  padding-top: 15px;
  border-top: 1px solid #E9ECEF;
  margin-top: 12px;
}

.total-label {
  font-size: 16px;
  font-weight: 600;
  color: #212529;
}

.total-value {
  font-size: 20px;
  font-weight: 700;
  color: #FF6633;
}

/* 备注信息 */
.remark-section {
  background: #FFFFFF;
  margin: 0 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.remark-input {
  width: 100%;
  height: 48px;
  background: #F8F9FA;
  border: 1px solid #E9ECEF;
  border-radius: 12px;
  padding: 0 12px;
  font-size: 14px;
  color: #212529;
  margin-top: 12px;
}

/* 优惠券 */
.coupon-section {
  background: #FFFFFF;
  margin: 0 20px 16px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.coupon-section:active {
  transform: translateY(2px);
}

.coupon-info {
  font-size: 14px;
  color: #6C757D;
}

.coupon-value {
  font-size: 14px;
  color: #FF6633;
  font-weight: 500;
}

.arrow-icon {
  font-size: 16px;
  color: #6C757D;
}

/* 支付方式 */
.payment-section {
  background: #FFFFFF;
  margin: 0 20px 20px;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.payment-options {
  margin-top: 12px;
}

.payment-option {
  display: flex;
  align-items: center;
  padding: 16px;
  border: 1px solid #E9ECEF;
  border-radius: 12px;
  margin-bottom: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.payment-option.selected {
  border-color: #FF6633;
  background: rgba(255, 102, 51, 0.05);
}

.payment-icon {
  font-size: 24px;
  margin-right: 12px;
}

.payment-name {
  flex: 1;
  font-size: 16px;
  color: #212529;
  font-weight: 500;
}

.payment-radio {
  font-size: 20px;
  color: #FF6633;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: #FFFFFF;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20px;
  z-index: 1000;
}

.total-info {
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 14px;
  color: #6C757D;
  margin-right: 8px;
}

.total-amount {
  font-size: 20px;
  font-weight: 700;
  color: #FF6633;
}

.action-buttons {
  display: flex;
  gap: 12px;
}

.cancel-btn {
  padding: 12px 24px;
  background: #F8F9FA;
  border: 1px solid #E9ECEF;
  border-radius: 24px;
  color: #6C757D;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cancel-btn:active {
  transform: scale(0.95);
}

.confirm-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border: none;
  border-radius: 24px;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(255, 102, 51, 0.3);
}

.confirm-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2px 6px rgba(255, 102, 51, 0.2);
}

.confirm-btn:disabled {
  background: #BDBDBD;
  cursor: not-allowed;
  box-shadow: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .address-section,
  .store-section,
  .items-section,
  .cost-section,
  .remark-section,
  .coupon-section,
  .payment-section {
    margin-left: 15px;
    margin-right: 15px;
    padding: 15px;
  }

  .bottom-actions {
    padding: 0 15px;
  }

  .cancel-btn {
    padding: 10px 16px;
    font-size: 12px;
  }

  .confirm-btn {
    padding: 10px 20px;
    font-size: 14px;
  }

  .item-details {
    flex-direction: column;
    align-items: flex-start;
  }

  .item-price {
    margin-top: 4px;
  }
}

/* 动画效果 */
@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.address-section,
.store-section,
.items-section,
.cost-section,
.remark-section,
.coupon-section,
.payment-section {
  animation: slideInUp 0.5s ease forwards;
}

.store-section { animation-delay: 0.1s; }
.items-section { animation-delay: 0.2s; }
.cost-section { animation-delay: 0.3s; }
.remark-section { animation-delay: 0.4s; }
.coupon-section { animation-delay: 0.5s; }
.payment-section { animation-delay: 0.6s; }

/* 优惠券选择弹窗 */
.coupon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.coupon-modal-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.coupon-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.coupon-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #212529;
}

.coupon-modal-close {
  font-size: 40rpx;
  color: #9E9E9E;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coupon-list {
  flex: 1;
  padding: 0 32rpx 32rpx;
  max-height: 50vh;
}

.coupon-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.coupon-option:last-child {
  border-bottom: none;
}

.coupon-option.coupon-selected {
  background: rgba(255, 102, 51, 0.03);
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  border-radius: 16rpx;
}

.coupon-option.coupon-disabled {
  opacity: 0.4;
}

.coupon-option-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.coupon-no-use {
  font-size: 30rpx;
  color: #6C757D;
}

.coupon-amount-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.coupon-symbol {
  font-size: 24rpx;
  color: #FF6633;
  font-weight: 700;
}

.coupon-amount {
  font-size: 52rpx;
  color: #FF6633;
  font-weight: 800;
  line-height: 1;
}

.coupon-desc {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.coupon-name {
  font-size: 28rpx;
  color: #212529;
  font-weight: 600;
}

.coupon-condition {
  font-size: 22rpx;
  color: #9E9E9E;
}

.coupon-option-check {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 24rpx;
  color: transparent;
}

.check-icon.checked {
  color: #fff;
}

.coupon-selected .coupon-option-check {
  background: #FF6633;
  border-color: #FF6633;
}