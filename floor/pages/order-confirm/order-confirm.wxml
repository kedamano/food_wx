<!-- 订单确认页面 -->
<scroll-view class="scrollarea" scroll-y type="list">
  <!-- 头部导航 -->
  <view class="header-nav">
    <view class="nav-left" bindtap="onBackClick">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">确认订单</text>
    <view class="nav-right" bindtap="onHomeClick">
      <text class="home-icon">首</text>
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="address-section" bindtap="onSelectAddress">
    <view class="address-header">
      <text class="section-title">收货地址</text>
      <text class="change-text">选择地址 →</text>
    </view>
    <view class="address-content" wx:if="{{selectedAddress}}">
      <view class="address-info">
        <text class="user-name">{{selectedAddress.name}}</text>
        <text class="user-phone">{{selectedAddress.phone}}</text>
      </view>
      <text class="address-detail">{{selectedAddress.province}} {{selectedAddress.city}} {{selectedAddress.district}} {{selectedAddress.detail}}</text>
    </view>
    <view class="address-empty" wx:else>
      <text class="empty-text">请选择收货地址</text>
    </view>
  </view>

  <!-- 商家信息 -->
  <view class="store-section">
    <view class="store-info">
      <text class="-store store-icon">🏪</text>
      <text class="store-name">{{orderInfo.store.name}}</text>
    </view>
    <view class="delivery-info">
      <text class="delivery-label">配送方式：</text>
      <text class="delivery-value">商家配送</text>
    </view>
    <view class="delivery-time">
      <text class="time-label">预计送达：</text>
      <text class="time-value">{{orderInfo.store.deliveryTime}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="items-section">
    <text class="section-title">商品清单</text>
    <view class="item-list">
      <view class="item-row" wx:for="{{orderInfo.items}}" wx:key="foodId">
        <view class="item-image">
          <image class="food-image" src="{{item.image}}" mode="aspectFill"></image>
          <text class="-utensils food-icon" wx:if="{{!item.image}}">🍴</text>
        </view>
        <view class="item-details">
          <text class="item-name">{{item.name}}</text>
          <text class="item-quantity">x{{item.quantity}}</text>
          <text class="item-price">¥{{item.totalPrice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 费用明细 -->
  <view class="cost-section">
    <text class="section-title">费用明细</text>
    <view class="cost-details">
      <view class="cost-row">
        <text class="cost-label">商品小计</text>
        <text class="cost-value">¥{{orderInfo.subtotal}}</text>
      </view>
      <view class="cost-row">
        <text class="cost-label">配送费</text>
        <text class="cost-value">¥{{orderInfo.deliveryFee}}</text>
      </view>
      <view class="cost-row" wx:if="{{selectedCoupon}}">
        <text class="cost-label discount-label">优惠券减免</text>
        <text class="cost-value discount-value">-¥{{selectedCoupon.discount}}</text>
      </view>
      <view class="cost-row total">
        <text class="total-label">实付金额</text>
        <text class="total-value">¥{{orderInfo.finalAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 备注信息 -->
  <view class="remark-section">
    <text class="section-title">备注信息</text>
    <input class="remark-input" 
           placeholder="给商家留言（可选）" 
           bind:input="onRemarkInput"
           maxlength="100" />
  </view>

  <!-- 优惠券 -->
  <view class="coupon-section" bindtap="onSelectCoupon">
    <view class="coupon-left">
      <text class="section-title">优惠券</text>
      <text class="coupon-info" wx:if="{{selectedCoupon}}">{{selectedCoupon.name}}</text>
    </view>
    <view class="coupon-right">
      <text class="coupon-value" wx:if="{{selectedCoupon}}">-¥{{selectedCoupon.discount}}</text>
      <text class="arrow-icon">→</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <text class="section-title">支付方式</text>
    <view class="payment-options">
      <view class="payment-option {{paymentMethod === 'wechat' ? 'selected' : ''}}" bindtap="onSelectPayment" data-method="wechat">
        <text class="-comment-dollar payment-icon">💳</text>
        <text class="payment-name">微信支付</text>
        <text class="payment-radio">{{paymentMethod === 'wechat' ? '✓' : '○'}}</text>
      </view>
      <view class="payment-option {{paymentMethod === 'balance' ? 'selected' : ''}}" bindtap="onSelectPayment" data-method="balance">
        <text class="-wallet payment-icon">●</text>
        <text class="payment-name">余额支付</text>
        <text class="payment-radio">{{paymentMethod === 'balance' ? '✓' : '○'}}</text>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 优惠券选择弹窗 -->
<view class="coupon-modal" wx:if="{{showCouponModal}}" bindtap="onCloseCouponModal">
  <view class="coupon-modal-content" catchtap="">
    <view class="coupon-modal-header">
      <text class="coupon-modal-title">选择优惠券</text>
      <text class="coupon-modal-close" bindtap="onCloseCouponModal">x</text>
    </view>
    <scroll-view class="coupon-list" scroll-y>
      <!-- 不使用优惠券 -->
      <view class="coupon-option {{!selectedCoupon ? 'coupon-selected' : ''}}" bindtap="onChooseCoupon" data-coupon="{{null}}">
        <view class="coupon-option-left">
          <text class="coupon-no-use">不使用优惠券</text>
        </view>
        <view class="coupon-option-check">
          <text class="check-icon {{!selectedCoupon ? 'checked' : ''}}">✓</text>
        </view>
      </view>
      <!-- 优惠券列表 -->
      <view class="coupon-option {{selectedCoupon && selectedCoupon.id === item.id ? 'coupon-selected' : ''}} {{orderInfo.subtotal < item.minAmount ? 'coupon-disabled' : ''}}"
            wx:for="{{coupons}}" wx:key="id" bindtap="onChooseCoupon" data-coupon="{{item}}">
        <view class="coupon-option-left">
          <view class="coupon-amount-wrap">
            <text class="coupon-symbol">¥</text>
            <text class="coupon-amount">{{item.discount}}</text>
          </view>
          <view class="coupon-desc">
            <text class="coupon-name">{{item.name}}</text>
            <text class="coupon-condition">{{item.condition}}，{{orderInfo.subtotal >= item.minAmount ? '可使用' : '未满足条件'}}</text>
          </view>
        </view>
        <view class="coupon-option-check">
          <text class="check-icon {{selectedCoupon && selectedCoupon.id === item.id ? 'checked' : ''}}">✓</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 底部结算栏 -->
<view class="bottom-actions">
  <view class="total-info">
    <text class="total-label">合计：</text>
    <text class="total-amount">¥{{orderInfo.finalAmount}}</text>
  </view>
  <view class="action-buttons">
    <button class="cancel-btn" bindtap="onCancelOrder">取消订单</button>
    <button class="confirm-btn" bindtap="onConfirmOrder" loading="{{isSubmitting}}">提交订单</button>
  </view>
</view>