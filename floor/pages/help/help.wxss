/* 帮助中心页面样式 */
page {
  background: #f5f5f7;
}

.container {
  min-height: 100vh;
}

/* 搜索栏 */
.search-section {
  position: relative;
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 70rpx 0 30rpx;
  background: #f5f5f7;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 54rpx;
  top: 42rpx;
  font-size: 28rpx;
}

/* 分类列表 */
.categories {
  padding: 20rpx 24rpx;
}

.category-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.category-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.category-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.category-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.category-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 问题列表 */
.questions-list {
  border-top: 1rpx solid #f0f0f0;
}

.question-item {
  border-bottom: 1rpx solid #f0f0f0;
}

.question-item:last-child {
  border-bottom: none;
}

.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.question-q {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  padding-right: 20rpx;
}

.question-arrow {
  font-size: 32rpx;
  color: #FF6633;
  font-weight: bold;
}

.question-answer {
  padding: 0 30rpx 24rpx;
  background: #fafafa;
}

.answer-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
  white-space: pre-line;
}

/* 联系客服 */
.contact-section {
  padding: 40rpx 24rpx 20rpx;
  text-align: center;
}

.contact-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.contact-methods {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.contact-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 36rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.contact-btn.primary {
  background: #FF6633;
  color: #fff;
}

.contact-btn .btn-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.service-time {
  font-size: 24rpx;
  color: #999;
}

.safe-area-bottom {
  height: 60rpx;
}
