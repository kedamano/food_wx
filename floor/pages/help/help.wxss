/* 帮助中心页面 - 统一设置风格 */
page {
  background: #f5f5f5;
}

.page-sub {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- 搜索栏 ---------- */
.search-wrap {
  margin: 0 24rpx 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 80rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
}

/* ---------- 分组 ---------- */
.sub-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片 ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.s-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  background: #fff;
  position: relative;
}

.s-cell::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.s-cell-last::after {
  display: none;
}

.s-cell-hover {
  background: #fafafa;
}

.s-cell-hd {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.s-cell-ft {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* ---------- 圆形图标 ---------- */
.s-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.s-icon text {
  font-size: 30rpx;
}

.s-icon-orange { background: rgba(255, 102, 51, 0.1); }
.s-icon-blue { background: rgba(59, 130, 246, 0.1); }
.s-icon-green { background: rgba(34, 197, 94, 0.1); }
.s-icon-purple { background: rgba(139, 92, 246, 0.1); }
.s-icon-gray { background: rgba(107, 114, 128, 0.1); }

/* ---------- 文字 ---------- */
.s-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
}

.s-desc {
  font-size: 26rpx;
  color: #999;
}

.s-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* ---------- FAQ 卡片 ---------- */
.faq-card {
  margin-bottom: 16rpx;
}

.faq-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
}

.faq-name {
  font-weight: 500;
}

.faq-arrow {
  font-size: 32rpx;
  color: #FF6633;
  font-weight: 500;
}

/* ---------- FAQ 问题列表 ---------- */
.faq-list {
  border-top: 1rpx solid #f0f0f0;
}

.faq-item {
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 32rpx;
}

.faq-q-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
  padding-right: 20rpx;
}

.faq-q-arrow {
  font-size: 28rpx;
  color: #FF6633;
  font-weight: 500;
  flex-shrink: 0;
}

.faq-answer {
  padding: 0 32rpx 22rpx;
  margin: 0 32rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.faq-answer-text {
  font-size: 26rpx;
  color: #888;
  line-height: 1.8;
  white-space: pre-line;
}

/* ---------- 服务提示 ---------- */
.service-tip {
  display: flex;
  justify-content: center;
  padding: 8rpx 24rpx 0;
  margin-bottom: 16rpx;
}

.service-tip-text {
  font-size: 24rpx;
  color: #bbb;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
