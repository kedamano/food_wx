<!-- 帮助中心页面 -->
<view class="page-sub">
  <!-- 搜索栏 -->
  <view class="search-wrap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索帮助问题..." value="{{searchKeyword}}" bindinput="onSearch" />
    </view>
  </view>

  <!-- 常见问题分类 -->
  <view class="sub-group" wx:for="{{categories}}" wx:key="id">
    <view class="s-card faq-card">
      <!-- 分类头部 -->
      <view class="faq-header" bindtap="onToggleCategory" data-id="{{item.id}}" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>{{item.iconText}}</text></view>
          <text class="s-title faq-name">{{item.name}}</text>
        </view>
        <view class="s-cell-ft">
          <text class="faq-arrow">{{expandedCategory === item.id ? '−' : '+'}}</text>
        </view>
      </view>
      <!-- 问题列表 -->
      <view class="faq-list" wx:if="{{expandedCategory === item.id}}">
        <view class="faq-item" wx:for="{{item.questions}}" wx:for-item="question" wx:key="q" wx:for-index="qIndex">
          <view class="faq-q" bindtap="onToggleQuestion" data-index="{{qIndex}}" hover-class="s-cell-hover">
            <text class="faq-q-text">{{question.q}}</text>
            <text class="faq-q-arrow">{{expandedQuestion === qIndex ? '−' : '+'}}</text>
          </view>
          <view class="faq-answer" wx:if="{{expandedQuestion === qIndex}}">
            <text class="faq-answer-text">{{question.a}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系客服 -->
  <view class="sub-group">
    <view class="group-title">联系客服</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onCopyPhone" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>📞</text></view>
          <text class="s-title">拨打热线</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">400-888-8888</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onFeedback" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>💬</text></view>
          <text class="s-title">在线反馈</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务时间 -->
  <view class="service-tip">
    <text class="service-tip-text">客服时间：周一至周日 9:00-21:00</text>
  </view>

  <view class="safe-bottom"></view>
</view>
