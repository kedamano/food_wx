/* 账号信息页面 - 统一设置风格 */
page {
  background: #f5f5f5;
}

.page-sub {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- 头像卡片 ---------- */
.avatar-card {
  margin-bottom: 24rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.avatar-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #FF6633;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 3rpx solid #fff;
}

.avatar-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.avatar-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

/* ---------- 分组 ---------- */
.sub-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片（复用设置页） ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.s-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  background: #fff;
  position: relative;
}

.s-cell::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.s-cell-last::after {
  display: none;
}

.s-cell-hover {
  background: #fafafa;
}

.s-cell-hd {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.s-cell-ft {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* ---------- 圆形图标 ---------- */
.s-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.s-icon text {
  font-size: 30rpx;
}

.s-icon-orange { background: rgba(255, 102, 51, 0.1); }
.s-icon-blue { background: rgba(59, 130, 246, 0.1); }
.s-icon-green { background: rgba(34, 197, 94, 0.1); }
.s-icon-purple { background: rgba(139, 92, 246, 0.1); }
.s-icon-gray { background: rgba(107, 114, 128, 0.1); }

/* ---------- 文字 ---------- */
.s-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
}

.s-desc {
  font-size: 26rpx;
  color: #999;
}

.s-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* ---------- 提示条 ---------- */
.tip-bar {
  display: flex;
  align-items: center;
  margin: 8rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 102, 51, 0.06);
  border-radius: 12rpx;
}

.tip-bar-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-bar-text {
  font-size: 24rpx;
  color: #999;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
