<!-- 账号信息页面 -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="info-card">
    <view class="avatar-section">
      <view class="avatar-wrapper" bindtap="onChooseAvatar">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="avatar-edit">
          <text class="edit-icon -camera">📷</text>
        </view>
      </view>
      <text class="avatar-tip">点击修改头像</text>
    </view>
  </view>

  <!-- 信息列表 -->
  <view class="info-list">
    <view class="info-item" bindtap="onEditUsername">
      <text class="item-label">用户名</text>
      <view class="item-content">
        <text class="item-value">{{userInfo.username || '未设置'}}</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="info-item" bindtap="onEditPhone">
      <text class="item-label">手机号</text>
      <view class="item-content">
        <text class="item-value">{{userInfo.phone}}</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="info-item" bindtap="onEditEmail">
      <text class="item-label">邮箱</text>
      <view class="item-content">
        <text class="item-value">{{userInfo.email}}</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <view class="info-item">
      <text class="item-label">注册时间</text>
      <view class="item-content">
        <text class="item-value gray">{{userInfo.createTime || '未知'}}</text>
      </view>
    </view>
  </view>

  <!-- 安全提示 -->
  <view class="safe-tip">
    <text class="tip-icon -lock">🔒</text>
    <text class="tip-text">为了您的账号安全，请绑定手机号和邮箱</text>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
