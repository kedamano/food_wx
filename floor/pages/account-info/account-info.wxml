<!-- 账号信息页面 -->
<view class="page-sub">
  <!-- 头像区域 -->
  <view class="s-card avatar-card">
    <view class="avatar-row" bindtap="onChooseAvatar" hover-class="s-cell-hover">
      <view class="avatar-wrap">
        <image class="avatar-img" src="{{userInfo.avatar || '/images/avatars/default.png'}}" mode="aspectFill"></image>
        <view class="avatar-badge">📷</view>
      </view>
      <view class="avatar-info">
        <text class="avatar-name">{{userInfo.username || '未设置用户名'}}</text>
        <text class="avatar-tip">点击更换头像</text>
      </view>
      <text class="s-arrow">›</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="sub-group">
    <view class="group-title">基本信息</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onEditUsername" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>👤</text></view>
          <text class="s-title">用户名</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{userInfo.username || '未设置'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onEditPhone" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>📱</text></view>
          <text class="s-title">手机号</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{userInfo.phone || '未绑定'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onEditEmail" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>✉️</text></view>
          <text class="s-title">邮箱</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{userInfo.email || '未绑定'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 其他信息 -->
  <view class="sub-group">
    <view class="group-title">其他</view>
    <view class="s-card">
      <view class="s-cell s-cell-last">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>📅</text></view>
          <text class="s-title">注册时间</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{userInfo.createTime || '未知'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 安全提示 -->
  <view class="tip-bar">
    <text class="tip-bar-icon">🔒</text>
    <text class="tip-bar-text">建议绑定手机号和邮箱以提高账号安全</text>
  </view>

  <view class="safe-bottom"></view>
</view>
