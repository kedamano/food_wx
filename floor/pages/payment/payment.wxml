<!-- 支付方式管理 -->
<scroll-view class="container" scroll-y>
  <!-- 头部 -->
  <view class="header-section">
    <view class="header-left">
      <text class="header-title">支付方式</text>
      <text class="header-subtitle">管理您的支付方式</text>
    </view>
    <view class="add-btn" bindtap="onAddPayment">
      <text class="btn-plus">+</text>
      <text class="btn-text">添加</text>
    </view>
  </view>

  <!-- 支付方式列表 -->
  <view class="payment-list">
    <view class="payment-card {{item.isDefault ? 'default-card' : ''}}"
          wx:for="{{paymentMethods}}" wx:key="id">

      <!-- 默认标签 -->
      <view class="default-badge" wx:if="{{item.isDefault}}">
        <text class="badge-text">默认</text>
      </view>

      <!-- 支付方式内容 -->
      <view class="payment-content">
        <view class="payment-icon-wrap">
          <text payment-icon-emoji>{{iconText || "💬"}}</text>
        </view>
        <view class="payment-info">
          <text class="payment-name">{{item.name}}</text>
          <text class="payment-number">{{item.number}}</text>
          <view class="payment-status">
            <text class="status-dot">●</text>
            <text class="status-text">{{item.status}}</text>
          </view>
        </view>
      </view>

      <!-- 操作行 -->
      <view class="action-row">
        <view class="set-default-btn" wx:if="{{!item.isDefault}}" catchtap="onSetDefault" data-id="{{item.id}}">
          <text class="set-default-text">设为默认</text>
        </view>
        <view class="action-spacer" wx:else></view>
        <view class="edit-btn" catchtap="onEditPayment" data-payment="{{item}}">
          <text class="action-text"><text class="-edit" style="margin-right:4rpx;">✏️</text>编辑</text>
        </view>
        <view class="delete-btn" catchtap="onDeletePayment" data-payment="{{item}}">
          <text class="action-text"><text class="-times" style="margin-right:4rpx;">✕</text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 安全提示 -->
  <view class="security-section">
    <view class="security-header">
      <text class="security-icon -lock">🔒</text>
      <text class="security-title">安全保障</text>
    </view>
    <view class="security-content">
      <text class="security-text">• 支付信息全程加密</text>
      <text class="security-text">• 支持指纹/面部识别</text>
      <text class="security-text">• 交易风险实时监控</text>
      <text class="security-text">• 7×24小时客服支持</text>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</scroll-view>
