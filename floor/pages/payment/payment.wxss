/* 支付方式管理 - 现代化CSS */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

/* 头部 */
.header-section {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.add-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.95);
}

/* 支付方式列表 */
.payment-list {
  padding-bottom: 20rpx;
}

.payment-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.payment-card.default {
  border-color: #4CAF50;
}

.payment-card:active {
  transform: scale(0.98);
}

.payment-content {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.payment-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 40rpx;
}

.payment-info {
  flex: 1;
}

.payment-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.payment-number {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.payment-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 22rpx;
  color: #4CAF50;
  margin-right: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #4CAF50;
}

.payment-actions {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn.default {
  background: #E8F5E8;
  color: #4CAF50;
}

.action-btn.edit {
  background: #F5F5F5;
  color: #666666;
}

.action-btn.delete {
  background: #FFE8E8;
  color: #FF6B6B;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 安全提示 */
.security-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.security-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.security-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.security-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.security-content {
  background: #F9F9F9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.security-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}