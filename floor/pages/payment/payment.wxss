/* 支付方式管理 */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* ===== 头部 ===== */
.header-section {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.add-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.add-btn:active { opacity: 0.8; }

.btn-plus {
  font-size: 32rpx;
  color: #fff;
  margin-right: 6rpx;
  line-height: 1;
}

.btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* ===== 支付卡片 ===== */
.payment-list {
  padding-bottom: 20rpx;
}

.payment-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  border: 2rpx solid transparent;
  position: relative;
}

.default-card {
  border-color: #FF6633;
}

.default-badge {
  background: #FF6633;
  padding: 6rpx 16rpx;
  border-radius: 0 0 12rpx 0;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.payment-content {
  display: flex;
  align-items: center;
  padding: 30rpx 30rpx 16rpx;
}

.payment-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.payment-icon-emoji {
  font-size: 44rpx;
}

.payment-info {
  flex: 1;
  padding-top: 6rpx;
}

.payment-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.payment-number {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.payment-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.status-dot {
  font-size: 16rpx;
  color: #FF6633;
}

.status-text {
  font-size: 22rpx;
  color: #FF6633;
}

/* ===== 操作行 ===== */
.action-row {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  border-top: 1rpx solid #F0F0F0;
  gap: 12rpx;
}

.action-spacer { flex: 1; }

.set-default-btn {
  flex: 1;
  padding: 8rpx 0;
}

.set-default-text {
  font-size: 24rpx;
  color: #FF6633;
}

.edit-btn,
.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
}

.edit-btn {
  background: #F5F5F5;
}

.delete-btn {
  background: #FFE8E8;
}

.edit-btn .action-text {
  font-size: 24rpx;
  color: #555;
}

.delete-btn .action-text {
  font-size: 24rpx;
  color: #FF6B6B;
}

/* ===== 安全提示 ===== */
.security-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.security-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.security-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.security-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.security-content {
  background: #F9F9F9;
  padding: 18rpx 20rpx;
  border-radius: 10rpx;
}

.security-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.9;
  display: block;
}

.safe-area-bottom {
  height: 40rpx;
}
