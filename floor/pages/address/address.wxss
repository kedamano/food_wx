/* 收货地址管理 */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #FF6633 0%, #FF8855 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.add-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 30rpx;
  padding: 14rpx 28rpx;
  border: none;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.add-btn::after { border: none; }

.btn-plus {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-right: 6rpx;
  line-height: 1;
}

.btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ===== 地址卡片 ===== */
.address-list {
  padding-bottom: 20rpx;
}

.address-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  border: 2rpx solid transparent;
  position: relative;
}

.default-card {
  border-color: #FF6633;
}

.default-badge {
  background: #FF6633;
  padding: 6rpx 16rpx;
  border-radius: 0 0 12rpx 0;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 地址内容区 */
.address-content {
  padding: 30rpx 30rpx 16rpx;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  padding-top: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #555555;
  flex: 1;
}

.tag-home {
  font-size: 20rpx;
  background: #FFF0EB;
  color: #FF6633;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.tag-work {
  font-size: 20rpx;
  background: #E8F4FF;
  color: #2196F3;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.addr-detail-box {
  background: #F9F9F9;
  padding: 18rpx;
  border-radius: 10rpx;
}

.addr-region {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 6rpx;
}

.addr-detail {
  font-size: 24rpx;
  color: #888;
  display: block;
}

/* ===== 操作行 ===== */
.action-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #F0F0F0;
  gap: 12rpx;
}

.action-spacer {
  flex: 1;
}

.set-default-btn {
  flex: 1;
  padding: 10rpx 0;
}

.set-default-text {
  font-size: 24rpx;
  color: #FF6633;
}

.edit-btn,
.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  gap: 6rpx;
}

.edit-btn {
  background: #FFF0EB;
}

.delete-btn {
  background: #FFE8E8;
}

.edit-icon {
  font-size: 26rpx;
  color: #FF6633;
}

.delete-icon {
  font-size: 26rpx;
  color: #FF6B6B;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
}

.edit-btn .action-text { color: #FF6633; }
.delete-btn .action-text { color: #FF6B6B; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 14rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.btn-primary {
  background: #FF6633;
  color: #FFFFFF;
  padding: 18rpx 56rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after { border: none; }

/* 加载 */
.loading-state {
  text-align: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}
