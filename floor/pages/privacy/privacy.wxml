<!-- 隐私设置页面 -->
<view class="page-sub">
  <!-- 权限设置 -->
  <view class="sub-group">
    <view class="group-title">权限设置</view>
    <view class="s-card">
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>📍</text></view>
          <text class="s-title">位置权限</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowLocation}}" bindchange="onSwitchChange" data-setting="allowLocation" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>📷</text></view>
          <text class="s-title">相机权限</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowCamera}}" bindchange="onSwitchChange" data-setting="allowCamera" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>🎤</text></view>
          <text class="s-title">麦克风权限</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowMicrophone}}" bindchange="onSwitchChange" data-setting="allowMicrophone" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell s-cell-last">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>🔔</text></view>
          <text class="s-title">消息通知</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowNotification}}" bindchange="onSwitchChange" data-setting="allowNotification" color="#FF6633" />
        </view>
      </view>
    </view>
  </view>

  <!-- 个人信息可见性 -->
  <view class="sub-group">
    <view class="group-title">个人信息可见性</view>
    <view class="s-card">
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>👁️</text></view>
          <text class="s-title">显示在线状态</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.showOnlineStatus}}" bindchange="onSwitchChange" data-setting="showOnlineStatus" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>🕐</text></view>
          <text class="s-title">显示最后登录</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.showLastLogin}}" bindchange="onSwitchChange" data-setting="showLastLogin" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>🔍</text></view>
          <text class="s-title">手机号搜索</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowSearchByPhone}}" bindchange="onSwitchChange" data-setting="allowSearchByPhone" color="#FF6633" />
        </view>
      </view>
      <view class="s-cell s-cell-last">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>🎯</text></view>
          <text class="s-title">个性化推荐</text>
        </view>
        <view class="s-cell-ft">
          <switch class="s-switch" checked="{{privacySettings.allowRecommendation}}" bindchange="onSwitchChange" data-setting="allowRecommendation" color="#FF6633" />
        </view>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="sub-group">
    <view class="group-title">数据管理</view>
    <view class="s-card">
      <view class="s-cell s-cell-last" bindtap="onClearLocationHistory" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>🗑️</text></view>
          <text class="s-title">清除位置历史</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 协议与政策 -->
  <view class="sub-group">
    <view class="group-title">协议与政策</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onPrivacyPolicy" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>📄</text></view>
          <text class="s-title">隐私政策</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onUserAgreement" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>📋</text></view>
          <text class="s-title">用户协议</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
