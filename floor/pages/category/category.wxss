/* 分类页面 - 大众点评风格 */
page {
  background: #f5f5f5;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部搜索栏 */
.top-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: relative;
  z-index: 10;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
  height: 72rpx;
}

.search-icon-text {
  font-size: 30rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 左右分栏 */
.content-area {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.left-sidebar {
  width: 180rpx;
  background: #f5f5f5;
  height: 100%;
  flex-shrink: 0;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 10rpx;
  position: relative;
  transition: all 0.2s;
}

.sidebar-item.active {
  background: #fff;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  background: #FF6633;
  border-radius: 0 4rpx 4rpx 0;
}

.sidebar-icon {
  font-size: 28rpx;
  color: #FF6633;
  margin-bottom: 6rpx;
  font-weight: 700;
}

.sidebar-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.sidebar-item.active .sidebar-name {
  color: #FF6633;
  font-weight: 600;
}

/* 右侧内容 */
.right-content {
  flex: 1;
  height: 100%;
  background: #fff;
  padding: 0 20rpx 20rpx;
}

/* 二级分类标签 */
.sub-category-section {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 0;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sub-tag {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
}

.sub-tag.active {
  background: rgba(255, 102, 51, 0.1);
  color: #FF6633;
  font-weight: 500;
}

/* 分类头图 */
.category-banner {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  gap: 20rpx;
}

.banner-bg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.banner-info {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.banner-count {
  font-size: 22rpx;
  color: #999;
}

/* 美食列表 */
.food-list {
  display: flex;
  flex-direction: column;
}

.food-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.food-card:last-child {
  border-bottom: none;
}

.food-img-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
  position: relative;
  flex-shrink: 0;
}

.food-img {
  width: 100%;
  height: 100%;
}

.food-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 12rpx 0;
}

.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  overflow: hidden;
}

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.food-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.food-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.food-price-box {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #FF6633;
  font-weight: 600;
}

.food-price {
  font-size: 32rpx;
  color: #FF6633;
  font-weight: 700;
  margin-right: 12rpx;
}

.food-sales {
  font-size: 20rpx;
  color: #999;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6633, #FF8855);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.3);
}

.add-btn:active {
  transform: scale(0.9);
}

.add-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
  margin-top: -2rpx;
}

.food-rating {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.stars {
  display: flex;
  margin-right: 6rpx;
}

.star {
  font-size: 20rpx;
  color: #FF6633;
}

.star:nth-child(n+4) {
  color: #ddd;
}

.rating-num {
  font-size: 22rpx;
  color: #FF6633;
  font-weight: 600;
  margin-right: 8rpx;
}

.review-count {
  font-size: 20rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 加载动画 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #FF6633;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
