/* 购物车页面 - 大众点评橙红风格 */

page {
  --primary: #FF6633;
  --primary-dark: #ee5522;
  --price-color: #FF6633;
  --text-main: #333;
  --text-sub: #666;
  --text-light: #999;
  --bg: #f5f5f5;
  --danger: #FF3B30;
  background: var(--bg);
}

.scrollarea {
  height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

/* 顶部导航 */
.header-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: var(--text-main);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.nav-right {
  width: 60rpx;
  display: flex;
  justify-content: flex-end;
}

.edit-text {
  font-size: 28rpx;
  color: var(--text-sub);
  font-weight: 500;
}

/* 商家信息 */
.store-section {
  background: #fff;
  margin-bottom: 16rpx;
}

.store-header {
  padding: 24rpx 32rpx;
}

.store-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.store-logo {
  font-size: 44rpx;
}

.store-details {
  flex: 1;
}

.store-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 6rpx;
  display: block;
}

.delivery-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--text-light);
  background: var(--bg);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* 购物车列表 */
.cart-section {
  background: #fff;
  margin-bottom: 16rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item:last-child {
  border-bottom: none;
}

.item-select {
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  height: 180rpx;
}

.item-checkbox {
  transform: scale(1.1);
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: var(--bg);
}

.food-image {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.food-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-middle {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.food-price {
  font-size: 34rpx;
  color: var(--price-color);
  font-weight: 700;
}

.food-subtotal {
  font-size: 22rpx;
  color: var(--text-light);
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  background: #fff;
  font-size: 32rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.quantity-btn:active {
  opacity: 0.7;
}

.plus-btn {
  color: var(--primary);
  border-color: var(--primary);
  background: rgba(255, 102, 51, 0.05);
}

.quantity-input {
  width: 64rpx;
  height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: none;
}

.item-delete {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.delete-btn {
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: var(--danger);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 28rpx;
  border: none;
  padding: 0;
}

.delete-btn::after {
  border: none;
}

/* 空购物车 */
.empty-cart {
  background: #fff;
  min-height: 60vh;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-main);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 48rpx;
}

.go-shopping-btn {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 51, 0.3);
}

.go-shopping-btn::after {
  border: none;
}

/* 优惠券 */
.coupon-section {
  background: #fff;
  margin-bottom: 16rpx;
}

.coupon-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.coupon-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.coupon-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.coupon-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.coupon-text {
  font-size: 26rpx;
  color: var(--primary);
  background: rgba(255, 102, 51, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.arrow-icon {
  font-size: 32rpx;
  color: var(--text-light);
}

/* 费用明细 */
.cost-section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 28rpx 32rpx;
}

.cost-section .section-title {
  display: block;
  margin-bottom: 20rpx;
}

.cost-details {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cost-label {
  font-size: 28rpx;
  color: var(--text-sub);
}

.cost-value {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
}

.cost-value.discount {
  color: var(--primary);
  font-weight: 600;
}

.cost-row-divider {
  border-top: 1rpx dashed #eee;
  padding-top: 20rpx;
  margin-top: 8rpx;
}

.total-label {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
}

.total-value {
  font-size: 44rpx;
  color: var(--price-color);
  font-weight: 800;
}

/* 推荐商品 */
.recommend-section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 28rpx 32rpx;
}

.recommend-list {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.recommend-item {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.recommend-img-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  background: var(--bg);
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-name {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 500;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommend-price {
  font-size: 28rpx;
  color: var(--price-color);
  font-weight: 700;
}

.add-btn {
  position: absolute;
  bottom: 80rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-size: 36rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 51, 0.3);
}

.add-btn::after {
  border: none;
}

/* 优惠券选择弹窗 */
.coupon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.coupon-modal-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.coupon-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.coupon-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.coupon-modal-close {
  font-size: 36rpx;
  color: var(--text-light);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coupon-list {
  flex: 1;
  padding: 0 32rpx 32rpx;
  max-height: 50vh;
}

.coupon-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.coupon-option:last-child {
  border-bottom: none;
}

.coupon-option.coupon-selected {
  background: rgba(255, 102, 51, 0.03);
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  border-radius: 16rpx;
}

.coupon-option.coupon-disabled {
  opacity: 0.45;
}

.coupon-option-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.coupon-no-use {
  font-size: 28rpx;
  color: var(--text-sub);
}

.coupon-amount-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.coupon-symbol {
  font-size: 24rpx;
  color: var(--price-color);
  font-weight: 700;
}

.coupon-amount {
  font-size: 48rpx;
  color: var(--price-color);
  font-weight: 800;
  line-height: 1;
}

.coupon-desc {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.coupon-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

.coupon-condition {
  font-size: 22rpx;
  color: var(--text-light);
}

.coupon-option-check {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 24rpx;
  color: transparent;
}

.check-icon.checked {
  color: #fff;
}

.coupon-selected .coupon-option-check {
  background: var(--primary);
  border-color: var(--primary);
}

/* 底部结算栏 */
.bottom-settle {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  z-index: 1000;
}

.settle-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.select-all-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.select-all {
  transform: scale(1.15);
}

.select-text {
  font-size: 26rpx;
  color: var(--text-sub);
}

.selected-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.settle-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.total-wrapper {
  display: flex;
  align-items: baseline;
}

.total-text {
  font-size: 28rpx;
  color: var(--text-sub);
}

.total-amount {
  font-size: 44rpx;
  color: var(--price-color);
  font-weight: 800;
}

.settle-btn {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 102, 51, 0.3);
}

.settle-btn::after {
  border: none;
}
