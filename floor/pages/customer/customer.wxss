/* 客服中心页面 */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  min-height: 100vh;
  padding-top: 20rpx;
}

/* 快捷操作 */
.quick-actions {
  padding: 0 24rpx 20rpx;
  display: flex;
  gap: 16rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-card:active {
  transform: scale(0.95);
}

.action-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrap.chat {
  background: #FFF0EB;
}

.action-icon-wrap.phone {
  background: #E8F4FF;
}

.action-icon-wrap.feedback {
  background: #FFF3E0;
}

.action-icon-text {
  font-size: 40rpx;
}

.action-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

/* 服务时间 */
.service-time-section {
  background: #fff;
  margin: 0 24rpx 20rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.time-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.time-value {
  font-size: 24rpx;
  color: #666;
}

/* FAQ */
.faq-section {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.faq-list {
  display: flex;
  flex-direction: column;
}

.faq-item {
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.faq-question {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.faq-arrow {
  font-size: 32rpx;
  color: #ccc;
  transition: transform 0.3s ease;
}

.faq-arrow.up {
  transform: rotate(90deg);
}

.faq-answer {
  padding-bottom: 24rpx;
}

.answer-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.safe-area-bottom {
  height: 40rpx;
}
