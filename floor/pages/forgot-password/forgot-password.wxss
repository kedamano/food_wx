/* 忘记密码页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0;
  padding: 0 20rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #ccc;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.step-item.active .step-number {
  background-color: #ff6b6b;
}

.step-text {
  font-size: 24rpx;
  color: #999;
}

.step-item.active .step-text {
  color: #ff6b6b;
  font-weight: bold;
}

.step-line {
  width: 100rpx;
  height: 4rpx;
  background-color: #eee;
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

.step-line::before {
  content: '';
  display: block;
  width: 0;
  height: 100%;
  background-color: #ff6b6b;
  transition: width 0.3s;
}

.step-item.active ~ .step-line::before {
  width: 100%;
}

/* 步骤内容 */
.step-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.form-section {
  width: 100%;
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.item-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.item-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 验证码容器 */
.verify-code-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.verify-input {
  flex: 1;
}

.verify-btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 30rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
  border: none;
}

.verify-btn::after {
  border: none;
}

.verify-btn.disabled {
  background-color: #ccc;
  color: #999;
}

/* 密码切换按钮 */
.password-toggle {
  position: absolute;
  right: 20rpx;
  top: 50rpx;
  font-size: 36rpx;
  cursor: pointer;
}

/* 按钮样式 */
.next-btn, .login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 40rpx;
}

.next-btn::after, .login-btn::after {
  border: none;
}

/* 成功页面 */
.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.success-message {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 44rpx;
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}

/* 错误提示 */
.error-message {
  display: block;
  width: 100%;
  text-align: center;
  color: #ff6b6b;
  font-size: 26rpx;
  margin-top: 20rpx;
  padding: 0 20rpx;
}