/* 优惠券管理 - 现代化CSS */
page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 积分头部 */
.points-header {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.points-content {
  flex: 1;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.points-balance {
  display: flex;
  align-items: flex-end;
}

.points-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.points-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
  margin-bottom: 6rpx;
}

.exchange-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  transition: all 0.3s ease;
  border: none;
  margin-left: 20rpx;
}

.exchange-btn:active {
  transform: scale(0.95);
}

.btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-right: 8rpx;
}

.btn-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  transition: transform 0.3s ease;
}

.exchange-btn:active .btn-icon {
  transform: translateX(4rpx);
}

/* 分类标签 */
.coupon-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 10rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  background: #4CAF50;
}

.tab-text {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #FFFFFF;
}

.tab-badge {
  font-size: 20rpx;
  color: #FF6B6B;
  background: #FFE8E8;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  min-width: 30rpx;
  text-align: center;
  font-weight: 600;
}

.tab-item.active .tab-badge {
  background: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
}

/* 优惠券列表 */
.coupon-list {
  padding-bottom: 20rpx;
}

.coupon-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  transition: all 0.3s ease;
  position: relative;
}

.coupon-card.used {
  opacity: 0.6;
}

.coupon-card.expired {
  opacity: 0.5;
}

.coupon-card:active {
  transform: scale(0.98);
}

.coupon-main {
  display: flex;
  align-items: center;
  padding: 30rpx;
  position: relative;
}

.coupon-amount {
  display: flex;
  align-items: flex-end;
  padding-right: 30rpx;
  border-right: 2rpx dashed #F0F0F0;
  margin-right: 30rpx;
  min-width: 160rpx;
}

.amount-symbol {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.amount-value {
  font-size: 56rpx;
  color: #FF6B6B;
  font-weight: 700;
  line-height: 1;
}

.coupon-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.coupon-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.coupon-condition {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.coupon-expiry {
  font-size: 22rpx;
  color: #999999;
}

.coupon-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 20rpx;
}

.status-text {
  font-size: 22rpx;
  color: #4CAF50;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.used .status-text {
  color: #999999;
}

.expired .status-text {
  color: #FF6B6B;
}

.status-icon {
  font-size: 40rpx;
}

/* 优惠券装饰 */
.coupon-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.coupon-decoration .circle {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  background: #F5F5F7;
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
}

.coupon-decoration .circle.left {
  left: -15rpx;
}

.coupon-decoration .circle.right {
  right: -15rpx;
}

.dashed-line {
  position: absolute;
  left: 160rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  border-left: 2rpx dashed #F0F0F0;
}

/* 推荐优惠券 */
.recommend-section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommend-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.recommend-card:active {
  transform: scale(0.98);
}

.recommend-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recommend-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.recommend-discount {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.recommend-condition {
  font-size: 22rpx;
  color: #999999;
}

.recommend-btn {
  background: #4CAF50;
  color: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  margin-left: 20rpx;
}

.recommend-btn:active {
  background: #45a049;
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  color: #CCCCCC;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: 40rpx;
}