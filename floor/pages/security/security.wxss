/* 安全设置页面 - 统一设置风格 */
page {
  background: #f5f5f5;
}

.page-sub {
  padding: 24rpx 0 0;
  min-height: 100vh;
}

/* ---------- 安全等级卡片 ---------- */
.level-card {
  margin-bottom: 24rpx;
}

.level-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.level-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.level-tag {
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
}

.level-tag-text {
  font-size: 24rpx;
}

.level-tag.high {
  background: rgba(34, 197, 94, 0.1);
}

.level-tag.high .level-tag-text {
  color: #16a34a;
}

.level-tag.medium {
  background: rgba(255, 165, 0, 0.1);
}

.level-tag.medium .level-tag-text {
  color: #e68a00;
}

.level-tag.low {
  background: rgba(255, 59, 48, 0.1);
}

.level-tag.low .level-tag-text {
  color: #FF3B30;
}

.level-bar-bg {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.level-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FF6633, #22c55e);
  transition: width 0.3s;
}

.level-tip {
  font-size: 24rpx;
  color: #999;
}

/* ---------- 分组 ---------- */
.sub-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 40rpx 12rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ---------- 卡片 ---------- */
.s-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.s-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  background: #fff;
  position: relative;
}

.s-cell::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.s-cell-last::after {
  display: none;
}

.s-cell-hover {
  background: #fafafa;
}

.s-cell-hd {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.s-cell-ft {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* ---------- 圆形图标 ---------- */
.s-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.s-icon text {
  font-size: 30rpx;
}

.s-icon-orange { background: rgba(255, 102, 51, 0.1); }
.s-icon-blue { background: rgba(59, 130, 246, 0.1); }
.s-icon-green { background: rgba(34, 197, 94, 0.1); }
.s-icon-purple { background: rgba(139, 92, 246, 0.1); }
.s-icon-gray { background: rgba(107, 114, 128, 0.1); }

/* ---------- 文字 ---------- */
.s-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 400;
}

.s-desc {
  font-size: 26rpx;
  color: #999;
}

.s-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

.s-cell-status {
  font-size: 26rpx;
  color: #FF6633;
}

.s-cell-status.bound {
  color: #999;
}

/* ---------- 底部安全区 ---------- */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
