<!-- 安全设置页面 -->
<view class="page-sub">
  <!-- 安全等级卡片 -->
  <view class="s-card level-card">
    <view class="level-top">
      <text class="level-label">账号安全等级</text>
      <view class="level-tag {{securityLevel}}">
        <text class="level-tag-text">{{securityLevelText}}</text>
      </view>
    </view>
    <view class="level-bar-bg">
      <view class="level-bar-fill" style="width: {{levelPercent}}%"></view>
    </view>
    <text class="level-tip">{{securityTip}}</text>
  </view>

  <!-- 账号绑定 -->
  <view class="sub-group">
    <view class="group-title">账号绑定</view>
    <view class="s-card">
      <view class="s-cell" bindtap="onBindPhone" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-green"><text>📱</text></view>
          <text class="s-title">手机号</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-cell-status {{phoneBound ? 'bound' : ''}}">{{phoneBound ? '已绑定' : '去绑定'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell" bindtap="onBindEmail" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-blue"><text>✉️</text></view>
          <text class="s-title">邮箱</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-cell-status {{emailBound ? 'bound' : ''}}">{{emailBound ? '已绑定' : '去绑定'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
      <view class="s-cell s-cell-last" bindtap="onBindWechat" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-orange"><text>💬</text></view>
          <text class="s-title">微信</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-cell-status {{bindWechat ? 'bound' : ''}}">{{bindWechat ? '已绑定' : '去绑定'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 密码安全 -->
  <view class="sub-group">
    <view class="group-title">密码安全</view>
    <view class="s-card">
      <view class="s-cell s-cell-last" bindtap="onChangePassword" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-purple"><text>🔑</text></view>
          <text class="s-title">登录密码</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-desc">{{passwordSet ? '已设置' : '未设置'}}</text>
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录设备 -->
  <view class="sub-group">
    <view class="group-title">其他</view>
    <view class="s-card">
      <view class="s-cell s-cell-last" bindtap="onDeviceManagement" hover-class="s-cell-hover">
        <view class="s-cell-hd">
          <view class="s-icon s-icon-gray"><text>📲</text></view>
          <text class="s-title">登录设备管理</text>
        </view>
        <view class="s-cell-ft">
          <text class="s-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
