/**app.wxss - 大众点评风格全局样式**/

/* CSS 变量 */
page {
  --primary: #FF6633;
  --primary-light: #FF8855;
  --primary-dark: #E55520;
  --orange: #FF8C00;
  --star-color: #FFB800;
  --bg: #F5F5F5;
  --bg-white: #FFFFFF;
  --text-main: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --text-placeholder: #CCCCCC;
  --border: #EEEEEE;
  --divider: #F0F0F0;
  --shadow: rgba(0, 0, 0, 0.06);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.6;
  box-sizing: border-box;
}

/* 全局容器 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 0;
  box-sizing: border-box;
}

/* Font Awesome 图标样式 */
.fa {
  font-family: 'FontAwesome';
}

/* 通用按钮 */
.btn {
  border-radius: var(--radius-lg);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
}

.btn-primary-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-ghost {
  background: rgba(255, 102, 51, 0.08);
  color: var(--primary);
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border);
  border-top: 4rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #F5F5F5 25%, #EAEAEA 50%, #F5F5F5 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
}

@keyframes loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-light);
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  color: var(--text-placeholder);
}

.empty-state-text {
  font-size: 30rpx;
  margin-bottom: 8rpx;
  color: var(--text-secondary);
}

.empty-state-subtext {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 通用卡片 */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  margin: 20rpx 24rpx;
  overflow: hidden;
}

.card-body {
  padding: 24rpx;
}

/* 通用分割线 */
.divider {
  height: 1rpx;
  background: var(--divider);
  margin: 0 24rpx;
}

/* 通用 flex 工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文本截断 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* 评分星星 */
.stars {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stars .fa-star {
  color: var(--star-color);
  font-size: 24rpx;
}

.stars .fa-star.empty {
  color: var(--text-placeholder);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  background: rgba(255, 102, 51, 0.08);
  color: var(--primary);
}

.tag-primary {
  background: var(--primary);
  color: #fff;
}

/* 价格 */
.price {
  color: var(--primary);
  font-weight: 600;
}

.price-symbol {
  font-size: 24rpx;
}

.price-integer {
  font-size: 40rpx;
  font-weight: 700;
}

.price-decimal {
  font-size: 28rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

@font-face {
  font-family: 'FontAwesome';
  src: url('./fonts/fa-solid-900.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
}
